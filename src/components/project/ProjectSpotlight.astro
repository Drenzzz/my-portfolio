---
import type { CollectionEntry } from "astro:content"
import { ArrowUpRight, GitBranch, Sparkles } from "lucide-react"

interface Props {
  projects: CollectionEntry<"projects">[]
}

const { projects } = Astro.props

const [heroProject, ...supportingProjects] = projects
const getProjectSlug = (id: string) => id.replace(/\.(md|mdx)$/, "")
---

{heroProject && (
  <section id="project-spotlight-motion-root" class="mb-14 md:mb-18">
    <div class="mb-7 flex items-center justify-between gap-4" data-motion-group="project-spotlight-header">
      <div data-motion>
        <p class="font-head text-[11px] font-black uppercase tracking-[0.3em] text-muted-foreground">
          Spotlight
        </p>
        <h2 class="mt-2 font-head text-3xl font-black uppercase tracking-tight md:text-4xl">
          Featured Builds
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6" data-motion-group="project-spotlight-cards">
      <article
        data-motion
        class="group overflow-hidden rounded-[28px] border-[3px] border-black bg-white shadow-brutal transition-all transition-neo hover:-translate-y-1 hover:shadow-none"
      >
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
          <a
            href={`/project/${getProjectSlug(heroProject.id)}`}
            class="relative block min-h-[320px] overflow-hidden border-b-[3px] border-black lg:min-h-[420px] lg:border-r-[3px] lg:border-b-0"
          >
            {heroProject.data.image && (
              <img
                src={heroProject.data.image}
                alt={heroProject.data.title}
                class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04] group-hover:-translate-y-1"
                loading="lazy"
              />
            )}

            <div class="project-featured-badge absolute left-5 top-5 inline-flex items-center gap-2 rounded-full border-2 border-black bg-[#C4A1FF] px-3 py-1.5 text-[11px] font-black uppercase tracking-[0.22em] shadow-brutal-sm">
              <Sparkles className="h-3.5 w-3.5" />
              Featured Build
            </div>
          </a>

          <div class="flex flex-col gap-5 p-6 lg:p-8">
            <div>
              <p class="text-[11px] font-black uppercase tracking-[0.25em] text-muted-foreground">
                Highlight project
              </p>
              <div class="mt-3 flex items-start justify-between gap-4">
                <a
                  href={`/project/${getProjectSlug(heroProject.id)}`}
                  class="font-head text-3xl font-black leading-none transition-colors hover:text-primary md:text-4xl"
                >
                  {heroProject.data.title}
                </a>
                <ArrowUpRight className="mt-1 h-5 w-5 shrink-0 text-muted-foreground transition-colors group-hover:text-primary" />
              </div>
            </div>

            <p class="max-w-xl text-base leading-relaxed font-medium text-muted-foreground">
              {heroProject.data.description}
            </p>

            <div class="rounded-2xl border-2 border-black bg-[#F4F4F5] p-4 shadow-brutal-sm">
              <p class="text-[11px] font-black uppercase tracking-[0.22em] text-muted-foreground">
                Why it stands out
              </p>
              <p class="mt-2 text-sm leading-relaxed font-medium text-black">
                One of the most complete builds in this portfolio with stronger product thinking, cleaner implementation, and a more polished execution end-to-end.
              </p>
            </div>

            <div class="flex flex-wrap gap-2">
              {heroProject.data.tags.slice(0, 5).map((tag) => (
                <span class="rounded-lg border-2 border-black bg-background px-2.5 py-1 text-xs font-bold font-head shadow-brutal-sm">
                  {tag}
                </span>
              ))}
            </div>

            <div class="mt-auto flex flex-wrap gap-3 border-t-2 border-black/10 pt-4">
              <a
                href={`/project/${getProjectSlug(heroProject.id)}`}
                class="inline-flex items-center gap-2 rounded-sm border-2 border-black bg-[#C4A1FF] px-4 py-2 text-sm font-black shadow-brutal-sm transition-all transition-neo-fast hover:-translate-y-[2px] hover:shadow-none"
              >
                Read case study
                <ArrowUpRight className="h-4 w-4" />
              </a>
              {heroProject.data.github && (
                <a
                  href={heroProject.data.github}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 rounded-sm border-2 border-black bg-white px-4 py-2 text-sm font-black shadow-brutal-sm transition-all transition-neo-fast hover:-translate-y-[2px] hover:shadow-none"
                >
                  <GitBranch className="h-4 w-4" />
                  Source code
                </a>
              )}
            </div>
          </div>
        </div>
      </article>

      {supportingProjects.length > 0 && (
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {supportingProjects.map((project) => (
            <a
              href={`/project/${getProjectSlug(project.id)}`}
              data-motion
              class="group overflow-hidden rounded-xl border-[3px] border-black bg-white shadow-brutal transition-all transition-neo hover:-translate-y-1 hover:shadow-none"
            >
              <div class="relative h-48 overflow-hidden border-b-[3px] border-black bg-black/5">
                {project.data.image && (
                  <img
                    src={project.data.image}
                    alt={project.data.title}
                    class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04] group-hover:-translate-y-1"
                    loading="lazy"
                  />
                )}
                <div class="project-featured-badge absolute left-4 top-4 rounded-full border-2 border-black bg-[#E7F193] px-2.5 py-1 text-[10px] font-black uppercase shadow-brutal-sm">
                  Featured
                </div>
              </div>

              <div class="p-5 lg:p-6">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="font-head text-2xl font-black leading-tight transition-colors group-hover:text-primary">
                    {project.data.title}
                  </h3>
                  <ArrowUpRight className="mt-1 h-5 w-5 shrink-0 text-muted-foreground transition-colors group-hover:text-primary" />
                </div>
                <p class="mt-3 text-[15px] leading-relaxed font-medium text-muted-foreground line-clamp-3">
                  {project.data.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
)}

<style>
  .project-featured-badge {
    animation: project-featured-glow 2.4s ease-in-out infinite;
  }

  @keyframes project-featured-glow {
    0%,
    100% {
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 1);
    }
    50% {
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 1), 0 0 0 6px rgba(196, 161, 255, 0.18);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-featured-badge {
      animation: none;
    }
  }
</style>

<script>
  import { bindInViewReveal } from "@/lib/animation/motion"

  const root = document.getElementById("project-spotlight-motion-root")

  if (root && root.dataset.motionBound !== "true") {
    root.dataset.motionBound = "true"

    bindInViewReveal(root, "[data-motion-group='project-spotlight-header'] [data-motion]", {
      amount: 0.2,
      delay: 0.04,
      duration: 0.38,
      staggerDelay: 0.12,
      offsetY: 14,
    })

    bindInViewReveal(root, "[data-motion-group='project-spotlight-cards'] [data-motion]", {
      amount: 0.16,
      delay: 0.1,
      duration: 0.45,
      staggerDelay: 0.12,
      offsetY: 22,
      scale: 0.98,
    })
  }
</script>
