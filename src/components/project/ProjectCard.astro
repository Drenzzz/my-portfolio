---
import { type CollectionEntry } from "astro:content"
import { GitBranch, ExternalLink, Folder } from "lucide-react"

interface Props {
  project: CollectionEntry<"projects">
  variant?: "default" | "supporting"
}

const { project } = Astro.props
const data = project.data
const projectSlug = project.id.replace(/\.(md|mdx)$/, "")
const variant = Astro.props.variant ?? "default"
const isSupporting = variant === "supporting"
---

<article
  class:list={[
    "group cursor-pointer overflow-hidden rounded-xl border-[3px] border-black bg-white shadow-brutal transition-all hover:-translate-y-1 hover:shadow-none flex flex-col",
    isSupporting && "h-full",
  ]}
  data-project-card
  data-tags={data.tags.join(",")}
  onclick={`window.location.href='/project/${projectSlug}'`}
>
  <div class:list={[
    "relative w-full overflow-hidden border-b-[3px] border-black bg-muted shrink-0",
    isSupporting ? "h-48" : "h-44",
  ]}>
    {data.image ? (
      <img
        src={data.image}
        alt={data.title}
        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05] group-hover:-translate-y-1"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-[#C4A1FF]/20">
        <Folder className="w-12 h-12 text-muted-foreground/30" />
      </div>
    )}

    {data.featured && (
      <span class="project-card-featured-badge absolute top-3 left-3 rounded border-2 border-black bg-[#C4A1FF] px-2.5 py-1 text-xs font-bold font-head uppercase shadow-brutal-sm">
        Featured
      </span>
    )}
  </div>

  <div class:list={[
    "flex flex-1 flex-col gap-3 p-5",
    isSupporting && "lg:p-6",
  ]}>
    <div class="flex items-start justify-between gap-3">
      <h3 class:list={[
        "font-head font-bold leading-tight transition-colors group-hover:text-primary",
        isSupporting ? "text-2xl" : "text-xl",
      ]}>
      {data.title}
      </h3>
      <span class="mt-1 text-sm font-black text-muted-foreground transition-colors group-hover:text-primary">
        ↗
      </span>
    </div>

    <p class:list={[
      "font-medium leading-relaxed text-muted-foreground",
      isSupporting ? "line-clamp-3 text-[15px]" : "line-clamp-2 text-sm",
    ]}>
      {data.description}
    </p>

    <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
      {data.tags.slice(0, isSupporting ? 5 : data.tags.length).map((tag) => (
        <span class="text-xs font-bold font-head px-2 py-0.5 border-2 border-black bg-background rounded shadow-brutal-sm">
          {tag}
        </span>
      ))}
      {isSupporting && data.tags.length > 5 && (
        <span class="text-xs font-bold font-head px-2 py-0.5 border-2 border-black bg-muted rounded shadow-brutal-sm">
          +{data.tags.length - 5}
        </span>
      )}
    </div>

    <div class="flex gap-3 pt-3 mt-1 border-t-2 border-black/10">
      {data.github && (
        <a
          href={data.github}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-1.5 text-xs font-bold font-head hover:text-primary transition-colors"
          onclick="event.stopPropagation()"
        >
          <GitBranch className="w-3.5 h-3.5" />
          Source Code
        </a>
      )}
      {data.link && (
        <a
          href={data.link}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-1.5 text-xs font-bold font-head text-primary hover:underline"
          onclick="event.stopPropagation()"
        >
          <ExternalLink className="w-3.5 h-3.5" />
          Live Demo
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card-featured-badge {
    animation: project-card-featured-glow 2.4s ease-in-out infinite;
  }

  @keyframes project-card-featured-glow {
    0%,
    100% {
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 1);
    }
    50% {
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 1), 0 0 0 6px rgba(196, 161, 255, 0.16);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card-featured-badge {
      animation: none;
    }
  }
</style>
