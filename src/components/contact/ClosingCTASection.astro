---
import { ArrowUpRight } from "lucide-react"
---

<section class="motion-target mt-8 md:mt-12 rounded-2xl border-[4px] border-black bg-[#C4A1FF] p-8 shadow-brutal transition-all hover:-translate-y-1 hover:translate-x-1 hover:shadow-[8px_8px_0px_#000] md:p-12">
  <div class="flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
    <div>
      <h2
        class="font-head text-3xl font-black text-black uppercase md:text-4xl"
      >
        Ready to Build Something?
      </h2>
      <p
        class="mt-3 max-w-lg text-base font-bold text-black/80"
      >
        Whether it is a full project, a quick consultation, or just a hello, I
        am always open to connecting. Let us make it happen.
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row">
      <a
        href="mailto:contact@drenzzz.dev"
        class="inline-flex items-center gap-2 rounded-sm border-3 border-black bg-white px-6 py-4 text-sm font-black text-black uppercase shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none"
      >
        Send Email
        <ArrowUpRight class="h-5 w-5" />
      </a>

      <a
        href="/project"
        class="inline-flex items-center gap-2 rounded-sm border-3 border-black bg-[#E7F193] px-6 py-4 text-sm font-black text-black uppercase shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none"
      >
        View Projects
        <ArrowUpRight class="h-5 w-5" />
      </a>
    </div>
  </div>
</section>

<script>
  import { revealMotionTargets } from "@/lib/animation/motion"

  const section = document.querySelector("section")
  if (section) {
    revealMotionTargets(section, {
      delay: 0,
      duration: 0.6,
      offsetY: 30,
      scale: 0.95,
    })
  }
</script>
