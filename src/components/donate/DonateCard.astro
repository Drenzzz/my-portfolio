---
import type { LocalDonation } from "@/types"
import { DonateCardIsland } from "@/components/islands/DonateCardIsland"

interface Props {
  method: LocalDonation;
}

const { method } = Astro.props
const qrImageSrc = method.imageKey
  ? `/images/donations/${method.imageKey}-qr.png`
  : undefined
---

<DonateCardIsland method={method} qrImageSrc={qrImageSrc} client:only="react" />
