---
import { Code2 } from "lucide-react"
import { skills } from "@/data/skills"

const categoryColors: Record<string, string> = {
  "Languages": "bg-[#E6A627]",          // Yellow
  "Frameworks & Libraries": "bg-[#38BDF8]", // Cyan
  "Database & ORM": "bg-[#4ADE80]",      // Green
  "Tools & Environment": "bg-[#F472B6]",   // Pink
  "Runtimes & Package Managers": "bg-[#FBBF24]", // Amber
  "Design": "bg-[#A78BFA]"              // Purple
};
---

<div class="h-full p-6 bg-white border-4 border-black rounded-xl shadow-brutal relative overflow-hidden transition-transform hover:rotate-1">
  <div class="flex items-center gap-3 mb-8">
    <div class="p-3 bg-black text-white rounded-sm border-2 border-black">
      <Code2 className="w-6 h-6" />
    </div>
    <div>
      <h3 class="font-head font-black text-2xl leading-none uppercase">Skills</h3>
      <p class="font-bold text-muted-foreground mt-1 text-sm tracking-wider uppercase">Technologies I use</p>
    </div>
  </div>

  <div class="space-y-6">
    {skills.map((category) => (
      <div class="space-y-3">
        <h4 class="font-head text-lg font-bold border-b-4 border-black inline-block pr-4 pb-1">
          {category.category}
        </h4>
        <div class="flex flex-wrap gap-2">
          {category.items.map((skill) => {
            const bgColor = categoryColors[category.category] || "bg-[#F4F4F5]";
            return (
              <span class={`px-3 py-1 font-bold text-sm ${bgColor} border-2 border-black shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all cursor-default`}>
                {skill}
              </span>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</div>
