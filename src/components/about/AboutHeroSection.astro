---
import { GitBranch, UserRound, Mail, Hand } from "lucide-react"

const profileImage = "https://github.com/drenzzz.png"
---

<section
  id="about-hero-motion-root"
  class="container mx-auto px-4"
  data-motion-group="about-hero"
>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-1">
      <div
        class="group relative flex h-full flex-col items-center justify-center overflow-hidden rounded-xl border-4 border-black bg-white p-8 shadow-brutal"
        data-motion
        style="--motion-offset-y: 20px; --motion-scale: 0.98;"
      >
        <div class="relative z-10 flex flex-col items-center gap-6">
          <div class="relative">
            <div
              class="h-40 w-40 overflow-hidden rounded-full border-4 border-black shadow-brutal-sm"
            >
              <img
                src={profileImage}
                alt="Drenzzz Profile"
                class="h-full w-full object-cover"
              />
            </div>
            <div
              class="absolute right-2 bottom-2 flex h-8 w-8 items-center justify-center rounded-full border-4 border-white bg-black"
              title="Open to Work/Internship"
            >
              <div class="h-3 w-3 animate-pulse rounded-full bg-[#C4A1FF]"></div>
            </div>
          </div>

          <div class="text-center">
            <h2 class="font-head mb-1 text-2xl font-black">
              Muhammad Naufal Nazya Azzharif
            </h2>
            <p
              class="text-sm font-bold tracking-wider text-muted-foreground uppercase"
            >
              Fullstack Developer
            </p>
          </div>

          <div class="flex items-center gap-3">
            <a
              href="https://github.com/drenzzz"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border-2 border-black bg-[#F4F4F5] p-2.5 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none"
              aria-label="Github"
            >
              <GitBranch className="h-5 w-5" />
            </a>
            <a
              href="mailto:contact@drenzzz.dev"
              class="rounded-lg border-2 border-black bg-[#F4F4F5] p-2.5 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-[#F31260] hover:text-white hover:shadow-none"
              aria-label="Email"
            >
              <Mail className="h-5 w-5" />
            </a>
            <a
              href="https://linkedin.com/in/muhammad-naufal-nazya-azzharif"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border-2 border-black bg-[#F4F4F5] p-2.5 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-[#006FEE] hover:text-white hover:shadow-none"
              aria-label="LinkedIn"
            >
              <UserRound className="h-5 w-5" />
            </a>
            <a
              href="https://facebook.com/realdrenzzz/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border-2 border-black bg-[#F4F4F5] p-2.5 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-[#0866FF] hover:text-white hover:shadow-none"
              aria-label="Facebook"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-facebook"
                ><path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                ></path></svg
              >
            </a>
            <a
              href="https://t.me/realdrenzzz"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border-2 border-black bg-[#F4F4F5] p-2.5 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-[#24A1DE] hover:text-white hover:shadow-none"
              aria-label="Telegram"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-send"
                ><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"
                ></path></svg
              >
            </a>
            <a
              href="https://discordapp.com/users/realdrenzzz"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border-2 border-black bg-[#F4F4F5] p-2.5 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-[#5865F2] hover:text-white hover:shadow-none"
              aria-label="Discord"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 127.14 96.36"
                fill="currentColor"
                ><path
                  d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.11,77.11,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.89,105.89,0,0,0,126.6,80.22c2.91-27.55-13.53-51.36-18.9-72.15ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"
                ></path></svg
              >
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div
        class="group relative flex h-full flex-col justify-center overflow-hidden rounded-xl border-4 border-black bg-[#C4A1FF] p-8 shadow-brutal"
        data-motion
        style="--motion-offset-y: 20px; --motion-scale: 0.98;"
      >
        <div class="relative z-10 space-y-4">
          <h3 class="font-head flex items-center gap-3 text-4xl font-black">
            Halo! <Hand
              className="h-8 w-8 fill-yellow-400 text-black md:h-10 md:w-10"
            />
          </h3>
          <div class="flex flex-col gap-4 text-lg leading-relaxed font-medium">
            <p>
              Saya <span
                class="font-bold underline decoration-white decoration-4 underline-offset-4"
                >Drenzzz</span
              >, atau <span class="bg-black px-1 font-bold text-white"
                >Muhammad Naufal Nazya Azzharif</span
              >.
            </p>
            <p>
              Saya adalah mahasiswa <strong
                class="border-2 border-black bg-white px-1 shadow-[2px_2px_0px_rgba(0,0,0,1)]"
                >D4 Teknologi Rekayasa Perangkat Lunak</strong
              > di Politeknik Negeri Padang yang berfokus pada pengembangan aplikasi
              full-stack.
            </p>
            <p>
              Saya aktif membangun
              <a
                href="/project"
                class="mx-1 border-b-4 border-black font-bold transition-colors hover:bg-black hover:text-white"
                >project nyata</a
              >
              meliputi aplikasi web, backend service, REST API, dan desktop tools menggunakan
              Next.js, React, TypeScript, Go, dan PostgreSQL. Saat ini saya terbuka
              untuk kesempatan <strong>internship</strong> guna berkontribusi langsung
              pada pengembangan solusi digital end-to-end.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { revealMotionGroup } from "@/lib/animation/motion"

  const root = document.getElementById("about-hero-motion-root")
  if (root && root.dataset.motionBound !== "true") {
    root.dataset.motionBound = "true"
    const targets = root.querySelectorAll("[data-motion]")
    targets.forEach((t) => t.classList.add("is-visible"))
    revealMotionGroup(targets, {
      delay: 0.08,
      duration: 0.45,
      staggerDelay: 0.12,
      offsetY: 20,
      scale: 0.98,
    })
  }
</script>
