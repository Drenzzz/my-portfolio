---
import { Github, Linkedin, Mail, Twitter, Code2 } from "lucide-react"

const profileImage = "https://github.com/drenzzz.png"
---

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
  <div class="lg:col-span-1">
    <div class="h-full p-8 bg-white border-4 border-black rounded-xl shadow-brutal flex flex-col items-center justify-center relative overflow-hidden group">
      <div class="relative z-10 flex flex-col items-center gap-6">
        <div class="relative">
          <div class="w-40 h-40 rounded-full overflow-hidden border-4 border-black shadow-brutal-sm">
            <img src={profileImage} alt="Drenzzz Profile" class="w-full h-full object-cover" />
          </div>
          <div class="absolute bottom-2 right-2 w-8 h-8 bg-black border-4 border-white rounded-full flex items-center justify-center" title="Open to Work/Internship">
            <div class="w-3 h-3 bg-[#E6A627] rounded-full animate-pulse"></div>
          </div>
        </div>
        
        <div class="text-center">
          <h2 class="font-head text-2xl font-black mb-1">Muhammad Naufal Nazya</h2>
          <p class="font-bold text-muted-foreground uppercase tracking-wider text-sm">Fullstack Developer</p>
        </div>
        
        <div class="flex items-center gap-3">
          <a href="https://github.com/drenzzz" target="_blank" rel="noopener noreferrer" class="p-2.5 bg-[#F4F4F5] border-2 border-black rounded-lg shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" aria-label="Github">
            <Github className="w-5 h-5" />
          </a>
          <a href="mailto:naufalnazya@gmail.com" class="p-2.5 bg-[#F4F4F5] border-2 border-black rounded-lg shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:bg-[#F31260] hover:text-white hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" aria-label="Email">
            <Mail className="w-5 h-5" />
          </a>
          <a href="https://linkedin.com/in/muhammad-naufal-nazya-azzharif" target="_blank" rel="noopener noreferrer" class="p-2.5 bg-[#F4F4F5] border-2 border-black rounded-lg shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:bg-[#006FEE] hover:text-white hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" aria-label="LinkedIn">
            <Linkedin className="w-5 h-5" />
          </a>
          <a href="https://facebook.com/realdrenzzz/" target="_blank" rel="noopener noreferrer" class="p-2.5 bg-[#F4F4F5] border-2 border-black rounded-lg shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:bg-[#0866FF] hover:text-white hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://t.me/realdrenzzz" target="_blank" rel="noopener noreferrer" class="p-2.5 bg-[#F4F4F5] border-2 border-black rounded-lg shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:bg-[#24A1DE] hover:text-white hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" aria-label="Telegram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          </a>
          <a href="https://discordapp.com/users/realdrenzzz" target="_blank" rel="noopener noreferrer" class="p-2.5 bg-[#F4F4F5] border-2 border-black rounded-lg shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:bg-[#5865F2] hover:text-white hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" aria-label="Discord">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.11,77.11,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.89,105.89,0,0,0,126.6,80.22c2.91-27.55-13.53-51.36-18.9-72.15ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="lg:col-span-2 flex flex-col gap-6">
    <div class="flex-1 p-8 bg-[#E6A627] border-4 border-black rounded-xl shadow-brutal relative overflow-hidden group">
      <div class="relative z-10 space-y-4">
        <h3 class="font-head text-4xl font-black">Halo! 👋</h3>
        <div class="font-medium text-lg leading-relaxed flex flex-col gap-4">
          <p>
            Saya <span class="font-bold underline decoration-4 decoration-white underline-offset-4">Drenzzz</span>, nama asli saya yaitu <span class="font-bold text-white bg-black px-1">Muhammad Naufal Nazya Azzharif</span>.
          </p>
          <p>
            Saat ini saya adalah mahasiswa <strong class="bg-white px-1 border-2 border-black shadow-[2px_2px_0px_rgba(0,0,0,1)]">Semester 5</strong> jurusan Teknologi Rekayasa Perangkat Lunak di Politeknik Negeri Padang.
          </p>
          <p>
            Meskipun belum memiliki pengalaman kerja formal, saya aktif membangun
            <a href="/project" class="font-bold mx-1 border-b-4 border-black hover:bg-black hover:text-white transition-colors">project aplikasi</a>
            untuk mengasah skill. Saya sangat antusias mencari kesempatan <strong>Magang</strong> atau Part-time untuk menerapkan apa yang sudah saya pelajari di dunia nyata.
          </p>
        </div>
      </div>
    </div>

    <div class="p-6 bg-white border-4 border-black rounded-xl shadow-brutal flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="text-center sm:text-left">
        <h3 class="font-head text-2xl font-black mb-1">Let's Connect!</h3>
        <p class="font-medium text-muted-foreground text-sm">Open for internship, freelance, or friendly chat</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="mailto:naufalnazya@gmail.com" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#E6A627] border-2 border-black rounded-sm font-bold shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
          <Mail className="w-4 h-4" />
          Get in Touch
        </a>
        <button disabled title="CV is currently being updated. Coming soon!" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#F4F4F5] border-2 border-slate-400 text-slate-500 rounded-sm font-bold shadow-[2px_2px_0px_rgba(148,163,184,1)] cursor-not-allowed transition-all grayscale hover:shadow-[2px_2px_0px_rgba(148,163,184,1)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-down"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>
          Download CV
        </button>
        <a href="/project" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border-2 border-black rounded-sm font-bold shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
          <Code2 className="w-4 h-4" />
          View Projects
        </a>
      </div>
    </div>
  </div>
</div>
