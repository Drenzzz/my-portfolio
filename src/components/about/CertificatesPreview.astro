---
import { getCollection } from "astro:content"
import { Award } from "lucide-react"
import {
  CertificatePreview,
  type CertificatePreviewItem,
} from "@/components/certificates/CertificatePreview"

const certificates = (await getCollection("certificates")).sort(
  (a, b) => a.data.order - b.data.order
)

const formatDate = (value: Date) => {
  return new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
  }).format(value)
}

const certificateItems: CertificatePreviewItem[] = certificates.map((entry) => ({
  slug: entry.id.replace(/\.(md|mdx)$/g, ""),
  title: entry.data.title,
  issuer: entry.data.issuer,
  dateLabel: formatDate(entry.data.date),
  category: entry.data.category,
  assetType: entry.data.assetType,
  asset: entry.data.asset,
  credentialUrl: entry.data.credentialUrl,
}))
---

<section
  id="certificates-motion-root"
  class="container mx-auto px-4 py-16 md:py-24"
  aria-labelledby="certificates-heading"
>
  <div class="mb-8 max-w-2xl" data-motion-group="certificates-header">
    <p
      class="font-head text-[11px] font-black uppercase tracking-[0.3em] text-muted-foreground"
      data-motion
    >
      Selected Proof
    </p>
    <div class="mt-2 flex items-end gap-4" data-motion-group="certificates-header">
      <h2
        id="certificates-heading"
        class="font-head text-3xl font-black uppercase tracking-tight md:text-4xl"
        data-motion
        style="--motion-offset-y: 16px;"
      >
        Certificates
      </h2>
      <span
        class="shrink-0 rounded bg-black px-2.5 py-1 text-xs font-black tracking-wider text-white shadow-[2px_2px_0px_rgba(0,0,0,1)]"
        data-motion
        style="--motion-offset-y: 16px;"
      >
        {certificates.length} Certificates
      </span>
    </div>
  </div>

  <div data-motion style="--motion-offset-y: 20px; --motion-scale: 0.98;">
    <CertificatePreview
      items={certificateItems}
      initialVisibleCount={3}
      client:load
    />
  </div>
</section>

<script>
  import { bindInViewReveal } from "@/lib/animation/motion"

  const root = document.getElementById("certificates-motion-root")
  if (root && root.dataset.motionBound !== "true") {
    root.dataset.motionBound = "true"

    bindInViewReveal(root, "[data-motion-group='certificates-header'] [data-motion]", {
      amount: 0.2,
      delay: 0.04,
      duration: 0.36,
      staggerDelay: 0.12,
      offsetY: 14,
    })

    bindInViewReveal(root, "[data-motion]", {
      amount: 0.16,
      delay: 0.12,
      duration: 0.45,
      staggerDelay: 0.12,
      offsetY: 20,
      scale: 0.97,
    })
  }
</script>
