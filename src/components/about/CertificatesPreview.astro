---
import { getCollection } from "astro:content"
import { ArrowUpRight, Award } from "lucide-react"

const certificates = (await getCollection("certificates"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3)

const formatDate = (value: Date) => {
  return new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
  }).format(value)
}
---

<section
  class="mt-8 rounded-xl border-[3px] border-black bg-white p-6 shadow-brutal"
>
  <div class="mb-5 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <div
        class="flex h-11 w-11 items-center justify-center rounded-xl border-2 border-black bg-[#C4A1FF] shadow-brutal-sm"
      >
        <Award className="h-5 w-5" />
      </div>
      <div>
        <p
          class="font-head text-[11px] font-black tracking-widest text-muted-foreground uppercase"
        >
          Selected Proof
        </p>
        <h2 class="font-head text-2xl font-black text-black uppercase">
          Featured Certificates
        </h2>
      </div>
    </div>

    <a
      href="/certificates"
      class="inline-flex items-center gap-2 rounded-sm border-2 border-black bg-[#C4A1FF] px-3 py-2 text-xs font-black text-black uppercase shadow-brutal-sm transition-all hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none"
    >
      View All
      <ArrowUpRight className="h-4 w-4" />
    </a>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
    {
      certificates.map((entry) => (
        <article class="group overflow-hidden rounded-xl border-[3px] border-black bg-[#F4F4F5] shadow-brutal-sm transition-all hover:-translate-y-1 hover:shadow-none">
          <div class="flex h-44 items-center justify-center border-b-[3px] border-black bg-white p-3">
            {entry.data.assetType === "image" && entry.data.asset ? (
              <img
                src={entry.data.asset}
                alt={entry.data.title}
                class="h-full w-full rounded-sm border-2 border-black object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="font-head flex h-full w-full items-center justify-center rounded-sm border-2 border-dashed border-black bg-[#C4A1FF]/20 p-4 text-center text-sm font-black text-black uppercase">
                {entry.data.assetType} preview
              </div>
            )}
          </div>

          <div class="p-4">
            <p class="font-head text-[11px] font-black tracking-widest text-muted-foreground uppercase">
              {entry.data.issuer}
            </p>
            <h3 class="font-head mt-1 text-lg leading-tight font-black text-black">
              {entry.data.title}
            </h3>
            <div class="mt-3 flex items-center justify-between gap-2 text-xs font-bold text-muted-foreground uppercase">
              <span>{entry.data.category}</span>
              <span>{formatDate(entry.data.date)}</span>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
