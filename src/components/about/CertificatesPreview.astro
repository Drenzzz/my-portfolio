---
import { getCollection } from "astro:content"
import { Award } from "lucide-react"
import {
  CertificatePreview,
  type CertificatePreviewItem,
} from "@/components/certificates/CertificatePreview"

const certificates = (await getCollection("certificates")).sort(
  (a, b) => a.data.order - b.data.order
)

const formatDate = (value: Date) => {
  return new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
  }).format(value)
}

const certificateItems: CertificatePreviewItem[] = certificates.map((entry) => ({
  slug: entry.id.replace(/\.(md|mdx)$/g, ""),
  title: entry.data.title,
  issuer: entry.data.issuer,
  dateLabel: formatDate(entry.data.date),
  category: entry.data.category,
  assetType: entry.data.assetType,
  asset: entry.data.asset,
  credentialUrl: entry.data.credentialUrl,
}))
---

<section
  class="mt-8 rounded-xl border-[3px] border-black bg-white p-6 shadow-brutal"
>
  <div class="mb-5 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <div
        class="flex h-11 w-11 items-center justify-center rounded-xl border-2 border-black bg-[#C4A1FF] shadow-brutal-sm"
      >
        <Award className="h-5 w-5" />
      </div>
      <div>
        <p
          class="font-head text-[11px] font-black tracking-widest text-muted-foreground uppercase"
        >
          Selected Proof
        </p>
        <h2 class="font-head text-2xl font-black text-black uppercase">
          Certificates
        </h2>
      </div>
    </div>
  </div>

  <CertificatePreview
    items={certificateItems}
    initialVisibleCount={3}
    client:load
  />
</section>
