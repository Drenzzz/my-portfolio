---
import { Calendar, GraduationCap } from "lucide-react"
import { education } from "@/data/education"
---

<div class="h-full p-6 bg-white border-4 border-black rounded-xl shadow-brutal relative overflow-hidden transition-transform hover:-rotate-1">
  <div class="flex items-center gap-3 mb-8">
    <div class="p-3 bg-black text-white rounded-sm border-2 border-black">
      <GraduationCap className="w-6 h-6" />
    </div>
    <div>
      <h3 class="font-head font-black text-2xl leading-none uppercase">Journey / Experience</h3>
      <p class="font-bold text-muted-foreground mt-1 text-sm tracking-wider uppercase">Academic & Beyond</p>
    </div>
  </div>
  
  <div class="relative border-l-4 border-black ml-4 space-y-8 pb-4">
    {education.map((item, index) => (
      <div class="relative pl-8 group">
        <!-- Timeline Marker -->
        <span class="absolute -left-[14px] top-1 h-6 w-6 rounded-full bg-[#5F4FE6] border-4 border-black group-hover:scale-125 transition-transform" />
        
        <div class="flex flex-wrap items-center gap-x-2 text-sm font-bold bg-black text-white px-2 py-0.5 rounded-sm w-fit mb-2 shadow-[2px_2px_0px_rgba(230,166,39,1)]">
          <Calendar className="w-3.5 h-3.5" />
          <span>{item.date}</span>
        </div>
        
        <h4 class="font-head text-xl font-bold leading-tight mb-1 group-hover:underline decoration-4 decoration-[#5F4FE6] underline-offset-4">{item.degree}</h4>
        <p class="font-medium text-muted-foreground">{item.school}</p>
        
        {item.description && (
          <p class="mt-2 text-sm font-medium">{item.description}</p>
        )}
      </div>
    ))}
  </div>
</div>
