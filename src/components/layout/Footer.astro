---
import { Github, Twitter, Linkedin, Mail } from "lucide-react"

const currentYear = new Date().getFullYear()
---

<footer class="mt-auto border-t-[3px] border-black bg-[#5F4FE6] text-black">
  <div class="container mx-auto py-8 lg:py-12 p-4">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div class="flex flex-col gap-2 text-center sm:text-left">
        <span class="font-head text-lg font-bold uppercase">Drenzzz</span>
        <p class="text-xs mt-2 font-medium opacity-80">
          © {currentYear} Drenzzz. All rights reserved.
        </p>
      </div>

      <div class="flex gap-4">
        <a href="https://github.com/drenzzz" target="_blank" rel="noreferrer" aria-label="GitHub" class="hover:-translate-y-1 transition-transform">
          <Github className="h-6 w-6" />
        </a>
        <a href="https://linkedin.com/in/muhammad-naufal-nazya-azzharif" target="_blank" rel="noreferrer" aria-label="LinkedIn" class="hover:-translate-y-1 transition-transform">
          <Linkedin className="h-6 w-6" />
        </a>
        <a href="https://facebook.com/realdrenzzz/" target="_blank" rel="noreferrer" aria-label="Facebook" class="hover:-translate-y-1 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://t.me/realdrenzzz" target="_blank" rel="noreferrer" aria-label="Telegram" class="hover:-translate-y-1 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
        </a>
        <a href="https://discordapp.com/users/realdrenzzz" target="_blank" rel="noreferrer" aria-label="Discord" class="hover:-translate-y-1 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.11,77.11,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.89,105.89,0,0,0,126.6,80.22c2.91-27.55-13.53-51.36-18.9-72.15ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg>
