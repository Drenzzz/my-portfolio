---
import { Github, Twitter, Linkedin, Mail } from "lucide-react"

const currentYear = new Date().getFullYear()
---

<footer class="mt-auto border-t-[3px] border-black bg-[#E6A627] text-black">
  <div class="container mx-auto py-8 lg:py-12 p-4">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div class="flex flex-col gap-2 text-center sm:text-left">
        <span class="font-head text-lg font-bold uppercase">Drenzzz</span>
        <p class="text-sm font-medium">Building robust systems and brutalist interfaces.</p>
        <p class="text-xs mt-2 font-medium opacity-80">
          © {currentYear} Drenzzz. All rights reserved.
        </p>
      </div>

      <div class="flex gap-4">
        <a href="https://github.com/drenzzz" target="_blank" rel="noreferrer" aria-label="GitHub" class="hover:-translate-y-1 transition-transform">
          <Github className="h-6 w-6" />
        </a>
        <a href="https://twitter.com/drenzzz" target="_blank" rel="noreferrer" aria-label="Twitter" class="hover:-translate-y-1 transition-transform">
          <Twitter className="h-6 w-6" />
        </a>
        <a href="https://linkedin.com/in/drenzzz" target="_blank" rel="noreferrer" aria-label="LinkedIn" class="hover:-translate-y-1 transition-transform">
          <Linkedin className="h-6 w-6" />
        </a>
        <a href="mailto:hello@drenzzz.dev" aria-label="Email" class="hover:-translate-y-1 transition-transform">
          <Mail className="h-6 w-6" />
        </a>
      </div>
    </div>
  </div>
</footer>
