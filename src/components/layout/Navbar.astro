---
import { navItems } from "@/data/navigation"
import { Menu, X } from "lucide-react"
---

<header class="sticky top-0 z-50 w-full border-b-[3px] border-black bg-background p-4 shadow-brutal transition-all duration-300 relative">
  <div class="container mx-auto flex h-14 items-center justify-between relative z-50 bg-background">
    <a href="/" class="flex flex-col gap-0.5 hover:-translate-y-[2px] hover:translate-x-[2px] transition-transform">
      <span class="font-head text-2xl font-black uppercase tracking-widest text-black drop-shadow-[2px_2px_0px_#C4A1FF]">Drenzzz</span>
    </a>

    {/* Desktop Navigation */}
    <nav class="hidden md:flex items-center justify-end gap-2 font-head font-bold text-sm ml-auto">
      {navItems.map((item) => (
        <a 
          href={item.path}
          class="px-4 py-2 border-2 border-transparent hover:border-black hover:bg-[#C4A1FF] hover:shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black uppercase tracking-wide"
        >
          {item.title}
        </a>
      ))}
    </nav>

    {/* Mobile Toggle Button */}
    <button 
      id="mobile-menu-toggle"
      class="md:hidden flex items-center justify-center p-2 border-2 border-black rounded-lg bg-[#C4A1FF] shadow-[2px_2px_0px_rgba(0,0,0,1)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all z-50"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <Menu className="w-6 h-6 menu-icon-open" />
      <X className="w-6 h-6 menu-icon-close hidden" />
    </button>
  </div>

  {/* Mobile Menu Overlay */}
  <div 
    id="mobile-menu-overlay"
    class="fixed inset-0 top-[83px] bg-background/80 backdrop-blur-md flex-col z-40 hidden border-t-[3px] border-black opacity-0"
  >
    <nav id="mobile-menu-content" class="flex flex-col items-center justify-center p-8 gap-6 h-full font-head font-black text-3xl overflow-y-auto pb-32">
      {navItems.map((item) => (
        <a 
          href={item.path}
          class="w-full text-center py-4 border-4 border-black bg-white shadow-[4px_4px_0px_rgba(0,0,0,1)] hover:bg-[#C4A1FF] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black transition-all transition-neo uppercase tracking-widest menu-item"
        >
          {item.title}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  import { animate, stagger } from "motion"
  import { shouldReduceMotion } from "@/lib/animation/motion"

  const setupMobileMenu = () => {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const overlay = document.getElementById('mobile-menu-overlay');
    const content = document.getElementById('mobile-menu-content');
    const iconOpen = toggleBtn?.querySelector('.menu-icon-open');
    const iconClose = toggleBtn?.querySelector('.menu-icon-close');
    const menuItems = overlay?.querySelectorAll('.menu-item');
    let isMenuOpen = false;
    let isAnimating = false;

    if (!toggleBtn || !overlay || !content || toggleBtn.dataset.motionBound === 'true') return;

    toggleBtn.dataset.motionBound = 'true';

    const openMenu = async () => {
      if (isAnimating) return;
      isAnimating = true;
      isMenuOpen = !isMenuOpen;
      toggleBtn.setAttribute('aria-expanded', isMenuOpen.toString());
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggleBtn.classList.replace('bg-[#C4A1FF]', 'bg-[#F31260]');
      toggleBtn.classList.add('text-white');

      if (shouldReduceMotion()) {
        overlay.classList.remove('opacity-0');
        overlay.classList.add('opacity-100');
        isAnimating = false;
        return;
      }

      await Promise.all([
        animate(overlay, { opacity: [0, 1] }, { duration: 0.22, ease: 'easeOut' }).finished,
        animate(content, { y: [-18, 0] }, { duration: 0.28, ease: [0.22, 1, 0.36, 1] }).finished,
        animate(
          menuItems ?? [],
          { opacity: [0, 1], y: [16, 0], x: [-8, 0] },
          { delay: stagger(0.05, { startDelay: 0.04 }), duration: 0.28, ease: [0.22, 1, 0.36, 1] }
        ).finished,
      ]);

      overlay.classList.remove('opacity-0');
      overlay.classList.add('opacity-100');
      isAnimating = false;
    };

    const closeMenu = async () => {
      if (isAnimating) return;
      isAnimating = true;
      isMenuOpen = !isMenuOpen;
      toggleBtn.setAttribute('aria-expanded', isMenuOpen.toString());

      if (shouldReduceMotion()) {
        overlay.classList.add('hidden');
        overlay.classList.remove('opacity-100');
        overlay.classList.add('opacity-0');
        document.body.style.overflow = '';
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        toggleBtn.classList.replace('bg-[#F31260]', 'bg-[#C4A1FF]');
        toggleBtn.classList.remove('text-white');
        isAnimating = false;
        return;
      }

      await Promise.all([
        animate(
          Array.from(menuItems ?? []).reverse(),
          { opacity: [1, 0], y: [0, 10] },
          { delay: stagger(0.035), duration: 0.18, ease: 'easeIn' }
        ).finished,
        animate(content, { y: [0, -12] }, { duration: 0.18, ease: 'easeIn' }).finished,
        animate(overlay, { opacity: [1, 0] }, { duration: 0.18, ease: 'easeIn' }).finished,
      ]);

      overlay.classList.add('hidden');
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0');
      document.body.style.overflow = '';
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggleBtn.classList.replace('bg-[#F31260]', 'bg-[#C4A1FF]');
      toggleBtn.classList.remove('text-white');
      isAnimating = false;
    };

    const toggleMenu = () => {
      if (isMenuOpen) {
        void closeMenu();
        return;
      }

      void openMenu();
    };

    toggleBtn.addEventListener('click', toggleMenu);

    menuItems?.forEach(item => {
      item.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });
  };

  setupMobileMenu();
</script>
