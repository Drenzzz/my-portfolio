---
import { getCollection } from "astro:content"
import { Button } from "@/components/retroui/Button"
import { Badge } from "@/components/retroui/Badge"
import { GitBranch, UserRound, ArrowUpRight, Folder, Award, Layers } from "lucide-react"
import { techStack } from "@/data/techStack"

const allProjects = await getCollection("projects")
const allCertificates = await getCollection("certificates")
const stats = [
  { label: "Projects", value: allProjects.length, icon: Folder },
  { label: "Certificates", value: allCertificates.length, icon: Award },
  { label: "Technologies", value: techStack.length, icon: Layers },
]
---

<div
  id="hero-motion-root"
  class="relative flex h-full w-full flex-col justify-center overflow-hidden rounded-xl border-4 border-black bg-[#F4F4F5] p-8 shadow-[8px_8px_0px_rgba(0,0,0,1)] md:p-12"
>
  <div
    class="pointer-events-none absolute inset-0 opacity-5"
    style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 20px 20px;"
  >
  </div>

  <div class="relative z-10 flex flex-col items-center justify-between gap-8 md:flex-row">
    <div class="flex w-full flex-col justify-center">
      <Badge
        variant="default"
        className="w-fit px-4 py-1.5 text-sm font-bold mb-6"
        data-motion
      >
        Hello World!
      </Badge>

      <h1
        class="font-head text-4xl font-black uppercase leading-[0.9] tracking-tight sm:text-5xl md:text-6xl lg:text-7xl mb-4"
        data-motion
        style="--motion-offset-y: 18px;"
      >
        I'M <span class="text-primary">DRENZZZ</span>.
      </h1>
      <typewriter-effect
        data-words='["Fullstack Developer", "System Enthusiast", "Open Source", "Web Developer"]'
        class="font-head mb-6 flex min-h-[28px] items-center text-lg font-bold text-muted-foreground md:min-h-[32px] md:text-xl"
        data-motion
        style="--motion-offset-y: 20px;"
      >
        <span class="typewriter-text"></span>
        <span class="ml-1 inline-block h-[1em] w-[2px] animate-blink bg-muted-foreground"></span>
      </typewriter-effect>

      <p
        class="mb-6 max-w-2xl text-sm leading-relaxed font-medium text-muted-foreground md:text-base"
        data-motion
        style="--motion-offset-y: 22px;"
      >
        Full-Stack Developer focused on building practical web applications, backend services, and desktop tools.
      </p>

      <div
        class="mb-6 w-fit"
        data-motion
        style="--motion-offset-y: 24px;"
      >
        <div class="flex items-center gap-3 rounded-lg border-2 border-black bg-white px-4 py-3 shadow-brutal-sm">
          <span class="h-2 w-2 shrink-0 rounded-full bg-[#C4A1FF]"></span>
          <p class="text-sm font-bold italic text-muted-foreground">
            "Ship it. Then make it right."
          </p>
        </div>
      </div>

      <div
        class="mb-8 flex flex-wrap gap-4"
        data-motion
        style="--motion-offset-y: 26px;"
      >
        {stats.map((stat) => (
          <div class="flex items-center gap-2 rounded-lg border-2 border-black bg-white px-3 py-2 shadow-brutal-sm">
            <stat.icon className="h-4 w-4 text-muted-foreground" />
            <span class="font-head text-lg font-black text-black">{stat.value}</span>
            <span class="text-xs font-bold uppercase tracking-wider text-muted-foreground">{stat.label}</span>
          </div>
        ))}
      </div>

      <div
        class="flex flex-wrap items-center gap-4"
        data-motion
        style="--motion-offset-y: 28px;"
      >
        <a href="/project">
          <Button variant="default" size="lg" className="shadow-[4px_4px_0px_rgba(0,0,0,1)] transition-all transition-neo-fast hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]">
            Explore Projects <ArrowUpRight className="ml-2 h-4 w-4" />
          </Button>
        </a>
        <div class="flex items-center gap-3 md:ml-4">
          <a href="https://github.com/drenzzz" target="_blank" rel="noreferrer" aria-label="GitHub"
             class="rounded-sm border-2 border-black bg-white p-2 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all transition-neo-fast hover:-translate-y-[2px] hover:bg-[#C4A1FF] hover:shadow-none">
            <GitBranch className="h-5 w-5" />
          </a>
          <a href="https://linkedin.com/in/muhammad-naufal-nazya-azzharif" target="_blank" rel="noreferrer" aria-label="LinkedIn"
             class="rounded-sm border-2 border-black bg-white p-2 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all transition-neo-fast hover:-translate-y-[2px] hover:bg-[#C4A1FF] hover:shadow-none">
            <UserRound className="h-5 w-5" />
          </a>
          <a href="https://facebook.com/realdrenzzz/" target="_blank" rel="noreferrer" aria-label="Facebook"
             class="rounded-sm border-2 border-black bg-white p-2 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all transition-neo-fast hover:-translate-y-[2px] hover:bg-[#C4A1FF] hover:shadow-none">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://t.me/realdrenzzz" target="_blank" rel="noreferrer" aria-label="Telegram"
             class="rounded-sm border-2 border-black bg-white p-2 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all transition-neo-fast hover:-translate-y-[2px] hover:bg-[#C4A1FF] hover:shadow-none">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          </a>
          <a href="https://discordapp.com/users/realdrenzzz" target="_blank" rel="noreferrer" aria-label="Discord"
             class="rounded-sm border-2 border-black bg-white p-2 shadow-[2px_2px_0px_rgba(0,0,0,1)] transition-all transition-neo-fast hover:-translate-y-[2px] hover:bg-[#C4A1FF] hover:shadow-none">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.11,77.11,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.89,105.89,0,0,0,126.6,80.22c2.91-27.55-13.53-51.36-18.9-72.15ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div
      class="relative z-10 hidden h-48 w-48 shrink-0 transition-transform duration-500 md:block lg:h-64 lg:w-64"
      data-motion
      style="--motion-offset-x: 20px; --motion-offset-y: 12px; --motion-scale: 0.96;"
    >
      <div class="absolute inset-0 translate-x-3 translate-y-3 rounded-2xl border-4 border-black bg-[#C4A1FF]"></div>
      <img
        src="https://github.com/drenzzz.png"
        alt="Drenzzz"
        width="512"
        height="512"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="relative h-full w-full rounded-2xl border-4 border-black bg-white object-cover grayscale-[20%] transition-all duration-300 hover:grayscale-0"
      />
    </div>
  </div>
</div>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink {
    animation: blink 1s step-end infinite;
  }
</style>

<script>
  import { revealMotionGroup, revealMotionTargets } from "@/lib/animation/motion"
  import { shouldReduceMotion } from "@/lib/animation/motion"

  class TypewriterEffect extends HTMLElement {
    timeoutId = 0;

    connectedCallback() {
      const words = JSON.parse(this.dataset.words || '[]');
      const span = this.querySelector('.typewriter-text');

      if (!span || !words.length) return;

      if (shouldReduceMotion()) {
        span.textContent = words[0];
        return;
      }

      let wordIndex = 0;
      let charIndex = 0;
      let isDeleting = false;

      const type = () => {
        const currentWord = words[wordIndex];

        charIndex += isDeleting ? -1 : 1;
        span.textContent = currentWord.substring(0, charIndex);

        let typeSpeed = isDeleting ? 50 : 100;

        if (!isDeleting && charIndex === currentWord.length) {
          typeSpeed = 2000;
          isDeleting = true;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          typeSpeed = 500;
        }

        this.timeoutId = window.setTimeout(type, typeSpeed);
      };

      type();
    }

    disconnectedCallback() {
      window.clearTimeout(this.timeoutId);
    }
  }
  
  if (!customElements.get('typewriter-effect')) {
    customElements.define('typewriter-effect', TypewriterEffect);
  }

  const heroRoot = document.getElementById("hero-motion-root")

  if (heroRoot && heroRoot.dataset.motionBound !== "true") {
    heroRoot.dataset.motionBound = "true"
    const contentTargets = heroRoot.querySelectorAll(".flex-col [data-motion]")
    const portraitTarget = heroRoot.querySelector("[data-motion][style*='--motion-offset-x']")

    contentTargets.forEach((target) => target.classList.add("is-visible"))

    revealMotionGroup(contentTargets, {
      delay: 0.12,
      duration: 0.42,
      staggerDelay: 0.07,
      offsetY: 18,
    })

    if (portraitTarget) {
      revealMotionTargets(portraitTarget, {
        delay: 0.34,
        duration: 0.5,
        offsetX: 20,
        offsetY: 12,
        scale: 0.96,
      })
    }
  }
</script>
