---
import { Button } from "@/components/retroui/Button"
import { Badge } from "@/components/retroui/Badge"
import { Github, Mail, Linkedin, Twitter, ArrowUpRight } from "lucide-react"
---

<section class="container mx-auto px-4 py-12 md:py-20 lg:py-28">
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-center">
    <div class="lg:col-span-3 flex flex-col gap-6">
      <Badge client:load variant="default" className="w-fit text-sm font-bold px-4 py-1.5">
        Hello World! 👋
      </Badge>

      <div class="space-y-3">
        <h1 class="font-head text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black uppercase tracking-tight leading-[0.9]">
          I'm <span class="text-primary">Drenzzz</span>.
        </h1>
        <p class="font-head text-xl md:text-2xl font-bold text-muted-foreground">
          Fullstack Developer · System Enthusiast · Open Source
        </p>
      </div>

      <p class="text-base md:text-lg text-muted-foreground leading-relaxed max-w-2xl font-medium">
        Cuma seseorang Developer pemula yang selalu ingin mencari tahu dan ingin belajar. Building robust systems and brutalist interfaces with Go, React, and Astro.
      </p>

      <div class="flex flex-wrap gap-3 pt-2">
        <a href="/project">
          <Button variant="default" size="lg" client:load>
            Explore Projects <ArrowUpRight className="ml-2 w-4 h-4" />
          </Button>
        </a>
        <a href="/about">
          <Button variant="outline" size="lg" client:load>
            More About Me
          </Button>
        </a>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <a href="https://github.com/drenzzz" target="_blank" rel="noreferrer" aria-label="GitHub"
           class="p-3 border-2 border-black bg-white shadow-brutal rounded-lg hover:-translate-y-1 hover:shadow-none transition-all">
          <Github className="w-5 h-5" />
        </a>
        <a href="mailto:naufalnazya@gmail.com" aria-label="Email"
           class="p-3 border-2 border-black bg-white shadow-brutal rounded-lg hover:-translate-y-1 hover:shadow-none transition-all">
          <Mail className="w-5 h-5" />
        </a>
        <a href="https://linkedin.com/in/drenzzz" target="_blank" rel="noreferrer" aria-label="LinkedIn"
           class="p-3 border-2 border-black bg-white shadow-brutal rounded-lg hover:-translate-y-1 hover:shadow-none transition-all">
          <Linkedin className="w-5 h-5" />
        </a>
        <a href="https://twitter.com/drenzzz" target="_blank" rel="noreferrer" aria-label="Twitter"
           class="p-3 border-2 border-black bg-white shadow-brutal rounded-lg hover:-translate-y-1 hover:shadow-none transition-all">
          <Twitter className="w-5 h-5" />
        </a>
      </div>
    </div>

    <div class="lg:col-span-2 flex items-center justify-center">
      <div class="relative w-full max-w-sm aspect-square border-4 border-black bg-[#E6A627] shadow-brutal rounded-2xl overflow-hidden flex items-center justify-center">
        <div class="text-center p-8">
          <div class="text-6xl mb-4">🧑‍💻</div>
          <p class="font-head text-xl font-black uppercase">Available for Work</p>
          <p class="text-sm font-medium mt-2">Freelance · Internship · OSS Collab</p>
        </div>
      </div>
    </div>
  </div>
</section>
