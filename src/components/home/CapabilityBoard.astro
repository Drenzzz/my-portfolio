---
import { techStack } from "@/data/techStack"

const groups = [
  {
    id: "core",
    label: "Languages",
    items: ["Go", "TypeScript", "JavaScript"],
    featured: ["Go", "TypeScript"],
    cardClass: "lg:col-span-2",
  },
  {
    id: "frontend",
    label: "Frontend",
    items: ["React", "Next.js", "Astro", "Tailwind CSS", "Vite"],
    featured: ["React", "Astro"],
    cardClass: "lg:col-span-2",
  },
  {
    id: "backend",
    label: "Backend & Runtime",
    items: ["Node.js", "Bun", "Hono.js", "Elysia.js", "Fiber", "Wails"],
    featured: ["Bun", "Hono.js"],
    cardClass: "lg:col-span-2",
  },
  {
    id: "infra",
    label: "Data & Infra",
    items: ["PostgreSQL", "MySQL", "Supabase", "Docker", "Linux", "Git"],
    featured: ["PostgreSQL", "Docker"],
    cardClass: "lg:col-span-4",
  },
  {
    id: "platforms",
    label: "Platforms",
    items: ["Vercel", "Netlify", "Cloudflare", "Figma"],
    featured: ["Vercel", "Cloudflare"],
    cardClass: "lg:col-span-2",
  },
] as const

const techMap = new Map(techStack.map((t) => [t.name, t.id]))
const iconOverrides = new Map([
  ["Elysia.js", "elysia"],
  ["Fiber", "go"],
])
---

<section
  id="capabilities-motion-root"
  class="container mx-auto px-4 py-12 md:py-16"
  aria-labelledby="capabilities-heading"
>
  <div class="mb-8 max-w-2xl">
    <p
      class="font-head text-[11px] font-black uppercase tracking-[0.3em] text-muted-foreground"
      data-motion
    >
      Capabilities
    </p>
    <h2
      id="capabilities-heading"
      class="mt-2 font-head text-3xl font-black uppercase tracking-tight md:text-4xl"
      data-motion
      style="--motion-offset-y: 16px;"
    >
      What I build with
    </h2>
    <p
      class="mt-3 text-sm font-medium leading-relaxed text-muted-foreground md:text-base"
      data-motion
      style="--motion-offset-y: 18px;"
    >
      Technologies I have been using to ship real projects, grouped by what they do.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-6">
    {groups.map((group) => (
      <article
        class:list={[
          "group relative overflow-hidden rounded-xl border-[3px] border-black bg-white p-5 shadow-brutal transition-all transition-neo hover:-translate-y-1 hover:shadow-none",
          group.cardClass,
          group.id === "core" && "lg:min-h-[250px]",
        ]}
        data-motion
        style="--motion-offset-y: 22px; --motion-scale: 0.98;"
      >
        <p class="mb-4 font-head text-[11px] font-black uppercase tracking-[0.2em] text-muted-foreground">
          {group.label}
        </p>

        <div class:list={[
          "flex flex-wrap gap-3 pr-18",
          group.id === "platforms" && "max-w-sm",
        ]}>
          {group.items.map((name) => {
            const id = iconOverrides.get(name) || techMap.get(name) || name.toLowerCase().replace(/\./g, "")
            const isFeatured = group.featured.includes(name)
            return (
              <div
                class:list={[
                  "inline-flex items-center gap-2.5 rounded-lg border-2 border-black px-3 py-2 shadow-brutal-sm transition-all transition-neo-fast hover:-translate-y-[2px] hover:shadow-none",
                  isFeatured ? "featured-chip bg-[#C4A1FF]" : "bg-[#F4F4F5]",
                  group.id === "platforms" && "w-[calc(50%-0.375rem)] justify-start",
                ]}
              >
                <img
                  src={`https://cdn.simpleicons.org/${id}/000000`}
                  alt=""
                  width="18"
                  height="18"
                  class="shrink-0"
                  loading="lazy"
                />
                <span class="text-sm font-bold text-black">{name}</span>
              </div>
            )
          })}
        </div>

        {group.id === "core" && (
          <p class="mt-4 max-w-sm text-sm font-medium leading-relaxed text-muted-foreground">
            The tools I reach for first when the work needs to stay fast, typed, and maintainable.
          </p>
        )}

        {group.id === "infra" && (
          <p class="mt-4 max-w-2xl text-sm font-medium leading-relaxed text-muted-foreground">
            The data and deployment layer I use to turn side projects into systems that can actually ship.
          </p>
        )}

      </article>
    ))}
  </div>
</section>

<style>
  .featured-chip {
    animation: capability-float 4.8s ease-in-out infinite;
  }

  article:nth-child(2) .featured-chip {
    animation-delay: 0.4s;
  }

  article:nth-child(3) .featured-chip {
    animation-delay: 0.9s;
  }

  article:nth-child(4) .featured-chip {
    animation-delay: 0.2s;
  }

  article:nth-child(5) .featured-chip {
    animation-delay: 0.7s;
  }

  @keyframes capability-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(0, -3px, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-chip {
      animation: none;
    }
  }
</style>

<script>
  import { bindInViewReveal } from "@/lib/animation/motion"

  const capabilitiesRoot = document.getElementById("capabilities-motion-root")

  if (capabilitiesRoot && capabilitiesRoot.dataset.motionBound !== "true") {
    capabilitiesRoot.dataset.motionBound = "true"

    bindInViewReveal(capabilitiesRoot, "[data-motion]", {
      amount: 0.18,
      delay: 0.05,
      duration: 0.4,
      staggerDelay: 0.08,
      offsetY: 18,
      scale: 0.98,
    })
  }
</script>
