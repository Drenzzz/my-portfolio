---
import { projects } from "@/data/projects"
import { Card } from "@/components/retroui/Card"
import { Badge } from "@/components/retroui/Badge"
import { ArrowUpRight, Folder } from "lucide-react"

const featured = projects.filter((p) => p.featured).slice(0, 3)
---

<section class="container mx-auto px-4 py-12 md:py-20">
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="p-2.5 bg-[#E6A627] border-2 border-black rounded-lg shadow-brutal">
        <Folder className="w-5 h-5" />
      </div>
      <div>
        <h2 class="font-head text-2xl md:text-3xl font-black uppercase">Featured Projects</h2>
        <p class="text-sm text-muted-foreground font-medium">Latest & greatest</p>
      </div>
    </div>
    <a href="/project" class="flex items-center gap-1 text-sm font-bold font-head hover:underline transition-colors">
      View all <ArrowUpRight className="w-4 h-4" />
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {featured.map((project) => (
      <div class="group border-[3px] border-black bg-white shadow-brutal rounded-xl overflow-hidden hover:-translate-y-1 hover:shadow-none transition-all">
        <div class="relative w-full h-40 bg-muted overflow-hidden border-b-[3px] border-black">
          {project.coverImage ? (
            <img
              src={project.coverImage}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-[#E6A627]/20">
              <Folder className="w-12 h-12 text-muted-foreground/30" />
            </div>
          )}
        </div>

        <div class="p-5 flex flex-col gap-3">
          <div class="flex items-start justify-between gap-2">
            <h3 class="font-head text-lg font-bold group-hover:text-primary transition-colors">{project.title}</h3>
            <ArrowUpRight className="w-4 h-4 text-muted-foreground group-hover:text-primary transition-colors shrink-0 mt-1" />
          </div>
          <p class="text-sm text-muted-foreground font-medium line-clamp-2">{project.summary}</p>
          <div class="flex flex-wrap gap-1.5">
            {project.tags.slice(0, 4).map((tag) => (
              <span class="text-xs font-bold font-head px-2 py-0.5 border-2 border-black bg-background rounded shadow-brutal-sm">
                {tag}
              </span>
            ))}
            {project.tags.length > 4 && (
              <span class="text-xs font-bold font-head px-2 py-0.5 border-2 border-black bg-muted rounded shadow-brutal-sm">
                +{project.tags.length - 4}
              </span>
            )}
          </div>
          <div class="flex gap-3 pt-1">
            {project.githubUrl && (
              <a href={project.githubUrl} target="_blank" rel="noreferrer"
                 class="text-xs font-bold font-head hover:underline">
                GitHub →
              </a>
            )}
            {project.liveUrl && (
              <a href={project.liveUrl} target="_blank" rel="noreferrer"
                 class="text-xs font-bold font-head text-primary hover:underline">
                Live Demo →
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
