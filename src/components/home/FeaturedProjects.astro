---
import { getCollection } from "astro:content"
import { ArrowUpRight, Folder, GitBranch, Sparkles } from "lucide-react"
import ProjectCard from "@/components/project/ProjectCard.astro"

const allProjects = await getCollection("projects")
const getProjectSlug = (id: string) => id.replace(/\.(md|mdx)$/, "")
const projectsBySlug = new Map(
  allProjects.map((project) => [getProjectSlug(project.id), project])
)

const heroProject = projectsBySlug.get("wiradoor")
const supportingProjects = [
  projectsBySlug.get("techyst"),
  projectsBySlug.get("adb-kit"),
].filter(Boolean)

if (!heroProject || supportingProjects.length !== 2) {
  throw new Error("Featured project showcase configuration is incomplete.")
}
---

<section id="featured-projects-motion-root" class="container mx-auto px-4 py-12 md:py-20">
  <div class="flex items-center justify-between mb-8" data-motion-group="projects-header">
    <div class="flex items-center gap-3" data-motion>
      <div class="p-2.5 bg-[#C4A1FF] border-2 border-black rounded-lg shadow-brutal">
        <Folder className="w-5 h-5" />
      </div>
      <div>
        <h2 class="font-head text-2xl md:text-3xl font-black uppercase">Featured Projects</h2>
        <p class="text-sm text-muted-foreground font-medium">Latest & greatest</p>
      </div>
    </div>
    <a href="/project" class="flex items-center gap-1 text-sm font-bold font-head hover:underline transition-colors transition-neo-fast" data-motion>
      View all <ArrowUpRight className="w-4 h-4" />
    </a>
  </div>

  <div class="grid grid-cols-1 gap-6">
    <article
      data-motion-group="projects-card"
      data-motion
      class="group overflow-hidden rounded-[28px] border-[3px] border-black bg-white shadow-brutal transition-all transition-neo hover:-translate-y-1 hover:shadow-none"
    >
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
        <a
          href={`/project/${getProjectSlug(heroProject.id)}`}
          class="relative block min-h-[320px] overflow-hidden border-b-[3px] border-black lg:min-h-[420px] lg:border-r-[3px] lg:border-b-0"
        >
          {heroProject.data.image ? (
            <img
              src={heroProject.data.image}
              alt={heroProject.data.title}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-[#C4A1FF]/20">
              <Folder className="h-16 w-16 text-muted-foreground/30" />
            </div>
          )}

          <div class="absolute left-5 top-5 inline-flex items-center gap-2 rounded-full border-2 border-black bg-[#E7F193] px-3 py-1.5 text-[11px] font-black uppercase tracking-[0.22em] shadow-brutal-sm">
            <Sparkles className="h-3.5 w-3.5" />
            Featured Build
          </div>
        </a>

        <div class="flex flex-col gap-5 p-6 lg:p-8">
          <div>
            <p class="text-[11px] font-black uppercase tracking-[0.25em] text-muted-foreground">
              Company profile + catalog system
            </p>
            <div class="mt-3 flex items-start justify-between gap-4">
              <a
                href={`/project/${getProjectSlug(heroProject.id)}`}
                class="font-head text-3xl font-black leading-none transition-colors hover:text-primary md:text-4xl"
              >
                {heroProject.data.title}
              </a>
              <ArrowUpRight className="mt-1 h-5 w-5 shrink-0 text-muted-foreground transition-colors group-hover:text-primary" />
            </div>
          </div>

          <p class="max-w-xl text-base leading-relaxed font-medium text-muted-foreground">
            {heroProject.data.description}
          </p>

          <div class="rounded-2xl border-2 border-black bg-[#F4F4F5] p-4 shadow-brutal-sm">
            <p class="text-[11px] font-black uppercase tracking-[0.22em] text-muted-foreground">
              Why it stands out
            </p>
            <p class="mt-2 text-sm leading-relaxed font-medium text-black">
              A full-stack digital showroom that blends marketing pages, guest checkout, inquiry handling, and internal admin workflows in one modular product.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            {heroProject.data.tags.slice(0, 5).map((tag) => (
              <span class="rounded-lg border-2 border-black bg-background px-2.5 py-1 text-xs font-bold font-head shadow-brutal-sm">
                {tag}
              </span>
            ))}
            {heroProject.data.tags.length > 5 && (
              <span class="rounded-lg border-2 border-black bg-muted px-2.5 py-1 text-xs font-bold font-head shadow-brutal-sm">
                +{heroProject.data.tags.length - 5}
              </span>
            )}
          </div>

          <div class="mt-auto flex flex-wrap gap-3 border-t-2 border-black/10 pt-4">
            <a
              href={`/project/${getProjectSlug(heroProject.id)}`}
              class="inline-flex items-center gap-2 rounded-sm border-2 border-black bg-[#C4A1FF] px-4 py-2 text-sm font-black shadow-brutal-sm transition-all transition-neo-fast hover:-translate-y-[2px] hover:shadow-none"
            >
              Read case study
              <ArrowUpRight className="h-4 w-4" />
            </a>
            {heroProject.data.github && (
              <a
                href={heroProject.data.github}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-2 rounded-sm border-2 border-black bg-white px-4 py-2 text-sm font-black shadow-brutal-sm transition-all transition-neo-fast hover:-translate-y-[2px] hover:shadow-none"
              >
                <GitBranch className="h-4 w-4" />
                Source code
              </a>
            )}
            {heroProject.data.link && (
              <a
                href={heroProject.data.link}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-2 rounded-sm border-2 border-black bg-[#E7F193] px-4 py-2 text-sm font-black shadow-brutal-sm transition-all transition-neo-fast hover:-translate-y-[2px] hover:shadow-none"
              >
                Open live site
                <ArrowUpRight className="h-4 w-4" />
              </a>
            )}
          </div>
        </div>
      </div>
    </article>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {supportingProjects.map((project) => (
        <div data-motion-group="projects-card" data-motion>
          <ProjectCard project={project} variant="supporting" />
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { bindInViewReveal } from "@/lib/animation/motion"

  const featuredProjectsRoot = document.getElementById("featured-projects-motion-root")

  if (featuredProjectsRoot && featuredProjectsRoot.dataset.motionBound !== "true") {
    featuredProjectsRoot.dataset.motionBound = "true"

    bindInViewReveal(featuredProjectsRoot, "[data-motion-group='projects-header'] [data-motion]", {
      amount: 0.2,
      delay: 0.04,
      duration: 0.36,
      staggerDelay: 0.08,
      offsetY: 14,
    })

    bindInViewReveal(featuredProjectsRoot, "[data-motion-group='projects-card']", {
      amount: 0.18,
      delay: 0.14,
      duration: 0.42,
      staggerDelay: 0.08,
      offsetY: 22,
      scale: 0.98,
    })
  }
</script>
