---
import { getCollection } from "astro:content"
import { Folder, ArrowUpRight } from "lucide-react"

const allProjects = await getCollection("projects")
const getProjectSlug = (id: string) => id.replace(/\.(md|mdx)$/, "")
const featured = allProjects
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .filter((p) => p.data.featured)
  .slice(0, 3)
---

<section id="featured-projects-motion-root" class="container mx-auto px-4 py-12 md:py-20">
  <div class="flex items-center justify-between mb-8" data-motion-group="projects-header">
    <div class="flex items-center gap-3" data-motion>
      <div class="p-2.5 bg-[#C4A1FF] border-2 border-black rounded-lg shadow-brutal">
        <Folder className="w-5 h-5" />
      </div>
      <div>
        <h2 class="font-head text-2xl md:text-3xl font-black uppercase">Featured Projects</h2>
        <p class="text-sm text-muted-foreground font-medium">Latest & greatest</p>
      </div>
    </div>
    <a href="/project" class="flex items-center gap-1 text-sm font-bold font-head hover:underline transition-colors transition-neo-fast" data-motion>
      View all <ArrowUpRight className="w-4 h-4" />
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {featured.map((project) => (
      <article data-motion-group="projects-card" data-motion class="group border-[3px] border-black bg-white shadow-brutal rounded-xl overflow-hidden hover:-translate-y-1 hover:shadow-none transition-all transition-neo flex flex-col">
        <div class="relative w-full h-40 bg-muted overflow-hidden border-b-[3px] border-black shrink-0">
          <a href={`/project/${getProjectSlug(project.id)}`} class="block w-full h-full" tabindex="-1">
            {project.data.image ? (
              <img
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-[#C4A1FF]/20">
                <Folder className="w-12 h-12 text-muted-foreground/30" />
              </div>
            )}
          </a>
        </div>

        <div class="p-5 flex flex-col flex-1 gap-3">
          <div class="flex items-start justify-between gap-2">
            <a href={`/project/${getProjectSlug(project.id)}`} class="font-head text-lg font-bold group-hover:text-primary transition-colors hover:underline">
              {project.data.title}
            </a>
            <ArrowUpRight className="w-4 h-4 text-muted-foreground group-hover:text-primary transition-colors shrink-0 mt-1" />
          </div>
          <p class="text-sm text-muted-foreground font-medium line-clamp-2">{project.data.description}</p>
          <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
            {project.data.tags.slice(0, 4).map((tag) => (
              <span class="text-xs font-bold font-head px-2 py-0.5 border-2 border-black bg-background rounded shadow-brutal-sm">
                {tag}
              </span>
            ))}
            {project.data.tags.length > 4 && (
              <span class="text-xs font-bold font-head px-2 py-0.5 border-2 border-black bg-muted rounded shadow-brutal-sm">
                +{project.data.tags.length - 4}
              </span>
            )}
          </div>
          <div class="flex gap-4 pt-3 mt-1 border-t-2 border-black/10">
            {project.data.github && (
              <a href={project.data.github} target="_blank" rel="noreferrer" class="text-xs font-bold font-head hover:underline flex items-center gap-1">
                GitHub ↗
              </a>
            )}
            {project.data.link && (
              <a href={project.data.link} target="_blank" rel="noreferrer" class="text-xs font-bold font-head text-primary hover:underline flex items-center gap-1">
                Live Demo ↗
              </a>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  import { bindInViewReveal } from "@/lib/animation/motion"

  const featuredProjectsRoot = document.getElementById("featured-projects-motion-root")

  if (featuredProjectsRoot && featuredProjectsRoot.dataset.motionBound !== "true") {
    featuredProjectsRoot.dataset.motionBound = "true"

    bindInViewReveal(featuredProjectsRoot, "[data-motion-group='projects-header'] [data-motion]", {
      amount: 0.2,
      delay: 0.04,
      duration: 0.36,
      staggerDelay: 0.08,
      offsetY: 14,
    })

    bindInViewReveal(featuredProjectsRoot, "[data-motion-group='projects-card']", {
      amount: 0.18,
      delay: 0.14,
      duration: 0.42,
      staggerDelay: 0.08,
      offsetY: 22,
      scale: 0.98,
    })
  }
</script>
