---
import { ArrowUpRight } from "lucide-react"
import { availability } from "@/data/availability"
---

<article
  class="section-slab relative overflow-hidden rounded-[28px] border-[3px] border-black bg-white p-6 shadow-brutal transition-all transition-neo hover:-translate-y-1 hover:shadow-none md:p-8 lg:grid lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-8"
>
  <div>
    <h3
      class="font-head text-3xl font-black text-black uppercase md:text-4xl lg:text-5xl"
    >
      {availability.status}
    </h3>
    <p
      class="mt-3 max-w-xl text-sm leading-relaxed font-medium text-muted-foreground md:text-base"
    >
      {availability.description}
    </p>
  </div>

  <div class="mt-6 flex flex-col gap-3 lg:mt-0 lg:items-end">
    <a
      href={availability.ctaHref}
      class="transition-neo-fast inline-flex w-fit items-center justify-center gap-2 rounded-sm border-2 border-black bg-[#C4A1FF] px-6 py-3 text-sm font-black text-black uppercase shadow-brutal-sm transition-all hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none"
    >
      {availability.ctaLabel}
      <ArrowUpRight className="h-4 w-4" />
    </a>

    <a
      href="/contact"
      class="transition-neo-fast inline-flex w-fit items-center justify-center gap-2 rounded-sm border-2 border-black bg-white px-6 py-3 text-sm font-black text-black uppercase shadow-brutal-sm transition-all hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none"
    >
      View Contact
      <ArrowUpRight className="h-4 w-4" />
    </a>
  </div>
</article>
