---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import { ContactForm } from "@/components/contact/ContactForm"
import ContactHeroSection from "@/components/contact/ContactHeroSection.astro"
import ClosingCTASection from "@/components/contact/ClosingCTASection.astro"

export const prerender = true

const title = "Contact | Drenzzz"
const description =
  "Reach out for projects, freelance work, internships, and collaboration opportunities."
---

<Layout title={title} description={description}>
  <Navbar />

  <main class="relative flex-1 overflow-hidden bg-[#f8f9fa]">
    <div
      class="absolute inset-0 z-0 opacity-[0.15]"
      style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 24px 24px;"
    >
    </div>
    <div
      class="floating-circle absolute top-28 left-10 z-0 h-32 w-32 rounded-full border-[3px] border-black bg-[#C4A1FF] opacity-70"
    >
    </div>
    <div
      class="floating-circle absolute bottom-40 right-14 z-0 h-24 w-24 rounded-full border-[3px] border-black bg-[#E7F193] opacity-70"
    >
    </div>
    <div class="relative z-10 container mx-auto px-4 py-12 md:py-20">
      <ContactHeroSection />

      <ContactForm client:load />

      <ClosingCTASection />
    </div>
  </main>

  <Footer />

  <style>
    .floating-circle {
      animation: float-circle 8s ease-in-out infinite;
    }

    .floating-circle:nth-child(2) {
      animation-delay: -2s;
      animation-duration: 10s;
    }

    @keyframes float-circle {
      0%, 100% {
        transform: translateY(0) translateX(0);
      }
      25% {
        transform: translateY(-12px) translateX(4px);
      }
      50% {
        transform: translateY(-6px) translateX(-6px);
      }
      75% {
        transform: translateY(-16px) translateX(2px);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .floating-circle {
        animation: none;
      }
    }
  </style>
</Layout>
