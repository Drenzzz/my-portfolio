---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import HeroSection from "@/components/home/HeroSection.astro"
import TechMarquee from "@/components/home/TechMarquee.astro"
import FeaturedProjects from "@/components/home/FeaturedProjects.astro"
import { DiscordStatus } from "@/components/home/DiscordStatus"
import { GitHubStats } from "@/components/home/GitHubStats"
import { LocationCard } from "@/components/home/LocationCard"
import { MusicPlayer } from "@/components/home/MusicPlayer"
import { fetchGithubStats } from "@/lib/github"

const githubStats = await fetchGithubStats()
---

<Layout>
  <Navbar />

  <main class="flex-1">
    <section class="container mx-auto px-4 py-8 md:py-12 flex flex-col gap-6">
      
      <!-- Top Row: Hero (3 cols) + Discord (1 col) -->
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <div class="lg:col-span-3 min-h-[400px]">
          <HeroSection />
        </div>
        <div class="lg:col-span-1 min-h-[350px] lg:min-h-[400px]">
          <DiscordStatus client:visible />
        </div>
      </div>

      <TechMarquee />

      <!-- Middle Row: Music Player (1 col), Location (1 col), Github (2 cols) -->
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <div class="lg:col-span-1 min-h-[300px]">
          <MusicPlayer client:visible />
        </div>
        <div class="lg:col-span-1 min-h-[300px]">
          <LocationCard client:visible />
        </div>
        <div class="lg:col-span-2 min-h-[300px]">
          <GitHubStats initialData={githubStats} />
        </div>
      </div>

    </section>

    <FeaturedProjects />
  </main>

  <Footer />
</Layout>
