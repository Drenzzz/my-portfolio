---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
---

<Layout>
  <Navbar />
  
  <main class="flex-1">
    <section class="container mx-auto py-12 md:py-24 lg:py-32">
      <div class="flex flex-col items-center text-center gap-8">
        <div class="inline-flex rounded-full border-2 border-black bg-[#E6A627] px-4 py-1.5 font-head text-sm font-bold shadow-brutal transition-transform hover:-translate-y-1">
          Available for new opportunities
        </div>
        
        <h1 class="font-head text-5xl sm:text-6xl md:text-8xl font-black uppercase tracking-tight text-foreground">
          Crafting <br class="hidden sm:block" />
          <span class="text-transparent bg-clip-text bg-gradient-to-br from-red-600 to-orange-500 stroke-text">Robust</span> 
          Systems
        </h1>
        
        <p class="max-w-[42rem] leading-normal text-muted-foreground sm:text-xl sm:leading-8 font-medium">
          I'm a Fullstack Developer building high-performance web applications and backend services with Go, React, and Astro. Neobrutalism enthusiast.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

