---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import HeroSection from "@/components/home/HeroSection.astro"
import TechMarquee from "@/components/home/TechMarquee.astro"
import FeaturedProjects from "@/components/home/FeaturedProjects.astro"
import AvailabilityCard from "@/components/home/AvailabilityCard.astro"
import { DiscordStatus } from "@/components/home/DiscordStatus"
import { GitHubStats } from "@/components/home/GitHubStats"
import { GuestbookPreview } from "@/components/home/GuestbookPreview"
import { LatestCommitsCard } from "@/components/home/LatestCommitsCard"
import { LocationCard } from "@/components/home/LocationCard"
import { MusicPlayer } from "@/components/home/MusicPlayer"
import { WakaTimeCard } from "@/components/home/WakaTimeCard"
import { ViewCounter } from "@/components/islands/ViewCounter"

export const prerender = true
---

<Layout>
  <Navbar />

  <main class="flex-1">
    <section class="container mx-auto px-4 py-8 md:py-12">
      <div class="flex justify-end">
        <ViewCounter pageKey="page:/" client:visible />
      </div>
    </section>

    <section class="container mx-auto px-4 pb-10 md:pb-14" aria-labelledby="home-intro-title">
      <h2 id="home-intro-title" class="sr-only">Home introduction</h2>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
        <div class="min-h-[400px] lg:col-span-3">
          <HeroSection />
        </div>
        <div class="min-h-[350px] lg:col-span-1 lg:min-h-[400px]">
          <DiscordStatus client:visible>
            <div
              slot="fallback"
              class="h-full w-full animate-pulse rounded-xl border-[3px] border-black bg-zinc-900"
              aria-hidden="true"
            >
            </div>
          </DiscordStatus>
        </div>
      </div>
    </section>

    <section aria-labelledby="home-stack-title" class="pb-10 md:pb-14">
      <h2 id="home-stack-title" class="sr-only">Tech stack</h2>
      <TechMarquee />
    </section>

    <FeaturedProjects />

    <section class="container mx-auto px-4 py-12 md:py-16" aria-labelledby="home-signals-title">
      <div class="mb-6 max-w-2xl">
        <p class="font-head text-[11px] font-black uppercase tracking-[0.3em] text-muted-foreground">
          Work Signals
        </p>
        <h2 id="home-signals-title" class="mt-2 font-head text-3xl font-black uppercase tracking-tight md:text-4xl">
          Proof that I build consistently
        </h2>
        <p class="mt-3 text-sm font-medium leading-relaxed text-muted-foreground md:text-base">
          A curated snapshot of coding activity, public repository momentum, and recent commits across ongoing work.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
        <div class="min-h-[220px] lg:col-span-2">
          <WakaTimeCard client:visible />
        </div>
        <div class="min-h-[220px] lg:col-span-2">
          <GitHubStats client:visible />
        </div>
      </div>

      <div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-4">
        <div class="min-h-[220px] lg:col-span-3">
          <LatestCommitsCard client:visible />
        </div>
        <div class="min-h-[220px] lg:col-span-1">
          <AvailabilityCard />
        </div>
      </div>
    </section>

    <section class="container mx-auto px-4 pb-14 md:pb-20" aria-labelledby="home-personal-title">
      <div class="mb-6 max-w-2xl">
        <p class="font-head text-[11px] font-black uppercase tracking-[0.3em] text-muted-foreground">
          Personal Layer
        </p>
        <h2 id="home-personal-title" class="mt-2 font-head text-3xl font-black uppercase tracking-tight md:text-4xl">
          The human side of the portfolio
        </h2>
        <p class="mt-3 text-sm font-medium leading-relaxed text-muted-foreground md:text-base">
          A lighter section for presence, routine, and notes that add personality without taking over the main story.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
        <div class="max-h-min min-h-[220px] lg:col-span-1">
          <MusicPlayer client:visible>
            <div
              slot="fallback"
              class="h-full w-full animate-pulse rounded-xl border-4 border-black bg-[#F4F4F5]"
              aria-hidden="true"
            >
            </div>
          </MusicPlayer>
        </div>
        <div class="max-h-min min-h-[220px] lg:col-span-1">
          <LocationCard client:visible>
            <div
              slot="fallback"
              class="h-full w-full animate-pulse rounded-xl border-4 border-black bg-[#F4F4F5]"
              aria-hidden="true"
            >
            </div>
          </LocationCard>
        </div>
        <div class="min-h-[220px] lg:col-span-2">
          <GuestbookPreview pageKey="page:/about" client:visible />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
