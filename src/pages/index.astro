---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import HeroSection from "@/components/home/HeroSection.astro"
import TechMarquee from "@/components/home/TechMarquee.astro"
import FeaturedProjects from "@/components/home/FeaturedProjects.astro"
import { DiscordStatus } from "@/components/home/DiscordStatus"
import { GitHubStats } from "@/components/home/GitHubStats"
import { fetchGithubStats } from "@/lib/github"

const githubStats = await fetchGithubStats()
---

<Layout>
  <Navbar />

  <main class="flex-1">
    <HeroSection />

    <TechMarquee />

    <FeaturedProjects />

    <section class="container mx-auto px-4 py-12 md:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-1 min-h-[320px]">
          <DiscordStatus client:idle />
        </div>
        <div class="lg:col-span-2">
          <GitHubStats client:visible initialData={githubStats} />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
