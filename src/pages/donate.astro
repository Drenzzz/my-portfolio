---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"

const title = "Donate | Drenzzz"
const description = "Support my open-source work and content creation."
---

<Layout title={title} description={description}>
  <Navbar />
  
  <main class="flex-1 container mx-auto py-12 px-4 flex flex-col items-center justify-center min-h-[60vh]">
    <h1 class="font-head text-4xl md:text-6xl font-black uppercase text-center mb-6">Support My Work</h1>
    <p class="text-lg text-muted-foreground font-medium text-center max-w-2xl mb-12">
      If you find my projects or articles helpful, consider buying me a coffee. Your support helps me maintain open-source projects and create more content.
    </p>
    
    <div class="w-full max-w-md bg-white border-4 border-black shadow-brutal p-8 text-center rounded-lg">
      <h2 class="font-head text-2xl font-bold mb-4">Donate Options</h2>
      <p class="font-medium">Details coming soon...</p>
      {/* Donation embed/info will go here */}
    </div>
  </main>

  <Footer />
</Layout>
