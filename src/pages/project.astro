---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import ProjectGrid from "@/components/project/ProjectGrid.astro"
import { TagFilter } from "@/components/project/TagFilter"
import { projects } from "@/data/projects"

const title = "Projects | Drenzzz"
const description = "Explore my portfolio of web applications, backend systems, and open-source contributions."
const totalProjects = projects.length
const uniqueTags = [...new Set(projects.flatMap((p) => p.tags))].sort()
---

<Layout title={title} description={description}>
  <Navbar />

  <main class="flex-1 container mx-auto py-12 md:py-20 px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10">
      <div>
        <h1 class="font-head text-4xl md:text-6xl font-black uppercase tracking-tight">
          Projects
        </h1>
        <p class="text-lg text-muted-foreground font-medium max-w-2xl mt-2">
          A collection of things I've built — from full-stack web apps to CLI tools and desktop applications.
        </p>
      </div>
      <div class="shrink-0 text-sm font-bold font-head px-3 py-1.5 border-2 border-black bg-[#E6A627] rounded shadow-brutal-sm">
        {totalProjects} Projects
      </div>
    </div>

    <TagFilter tags={uniqueTags} client:load />

    <ProjectGrid />
  </main>

  <Footer />
</Layout>

