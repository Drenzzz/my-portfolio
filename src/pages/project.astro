---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import ProjectGrid from "@/components/project/ProjectGrid.astro"
import { getCollection } from "astro:content"

const title = "Projects | Drenzzz"
const description = "Explore my portfolio of web applications, backend systems, and open-source contributions."

const allProjects = await getCollection("projects")
const totalProjects = allProjects.length
---

<Layout title={title} description={description}>
  <Navbar />

  <main class="flex-1 container mx-auto py-12 md:py-20 px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10">
      <div>
        <h1 class="font-head text-4xl md:text-6xl font-black uppercase tracking-tight">
          Projects
        </h1>
        <p class="text-lg text-muted-foreground font-medium max-w-2xl mt-2">
          A collection of things I've built.
        </p>
      </div>
      <div class="shrink-0 text-sm font-bold font-head px-3 py-1.5 border-2 border-black bg-[#5F4FE6] rounded shadow-brutal-sm">
        {totalProjects} Projects
      </div>
    </div>

    <ProjectGrid />
  </main>

  <Footer />
</Layout>

