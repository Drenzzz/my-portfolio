---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/main.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import { ArrowLeft, Calendar, Layers, Globe, GitBranch, ExternalLink, Info, X, ZoomIn, ZoomOut, ChevronLeft, ChevronRight } from "lucide-react";
import { ViewCounter } from "@/components/islands/ViewCounter";
import { ReactionBar } from "@/components/islands/ReactionBar";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(entry => ({
    params: { slug: entry.id.replace(/\.(md|mdx)$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const slug = entry.id.replace(/\.(md|mdx)$/, '');
const { Content } = await render(entry);
const galleryImages = entry.data.images?.length
  ? entry.data.images
  : entry.data.image
    ? [entry.data.image]
    : [];
const hasGallery = galleryImages.length > 1;

const formattedDate = new Date(entry.data.publishDate).toLocaleDateString("id-ID", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---
<Layout title={`${entry.data.title} | Drenzzz Projects`} description={entry.data.description}>
  <Navbar />
  
  <article class="flex-1 relative min-h-screen pb-20 pt-8">
    <div class="container mx-auto max-w-7xl px-4">
      <div class="mb-8 flex items-center gap-4 text-sm text-foreground">
        <a
          href="/project"
          class="group inline-flex items-center gap-2 rounded-sm border-2 border-black bg-white px-4 py-2 font-bold shadow-brutal-sm hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all"
        >
          <ArrowLeft className="h-4 w-4" />
          Kembali ke Portfolio
        </a>
      </div>

      <div class="grid gap-10 lg:grid-cols-[1.3fr_0.9fr]">
        <section class="space-y-8">
          <div class="rounded-xl border-[3px] border-black bg-white p-6 md:p-8 shadow-brutal">
            <div class="space-y-4">
              <h1 class="font-head text-4xl font-black leading-tight tracking-tight md:text-5xl lg:text-6xl uppercase">{entry.data.title}</h1>
              <p class="max-w-3xl text-lg text-muted-foreground md:text-xl font-medium">{entry.data.description}</p>
            </div>

            <div class="mt-8">
              <div class="relative overflow-hidden rounded-lg border-[3px] border-black bg-muted aspect-video shadow-brutal-sm">
                {galleryImages.length > 0 ? (
                  <>
                    <div
                      class="project-gallery flex h-full w-full overflow-x-auto snap-x snap-mandatory scroll-smooth"
                      data-gallery
                      data-gallery-images={JSON.stringify(galleryImages)}
                      aria-label={`Gallery for ${entry.data.title}`}
                    >
                      {galleryImages.map((image, index) => (
                        <div class="h-full w-full shrink-0 snap-center" aria-label={`Slide ${index + 1}`}>
                          <button
                            type="button"
                            class="h-full w-full cursor-zoom-in"
                            data-gallery-open
                            data-gallery-index={index}
                            aria-label={`Open ${entry.data.title} screenshot ${index + 1}`}
                          >
                            <img src={image} alt={`${entry.data.title} screenshot ${index + 1}`} class="h-full w-full object-cover" />
                          </button>
                        </div>
                      ))}
                    </div>

                    {hasGallery && (
                      <>
                        <button
                          type="button"
                          class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-sm border-2 border-black bg-white/90 px-3 py-2 text-xs font-black font-head uppercase shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[-50%] hover:shadow-none"
                          data-gallery-prev
                          aria-label="Previous image"
                        >
                          Prev
                        </button>
                        <button
                          type="button"
                          class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-sm border-2 border-black bg-white/90 px-3 py-2 text-xs font-black font-head uppercase shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[-50%] hover:shadow-none"
                          data-gallery-next
                          aria-label="Next image"
                        >
                          Next
                        </button>
                        <div class="absolute bottom-3 left-1/2 z-10 flex -translate-x-1/2 gap-2 rounded-full border-2 border-black bg-white/90 px-3 py-1" aria-hidden="true">
                          {galleryImages.map((_, index) => (
                            <span class={`h-2.5 w-2.5 rounded-full border border-black ${index === 0 ? "bg-black" : "bg-white"}`} data-gallery-dot />
                          ))}
                        </div>
                      </>
                    )}
                  </>
                ) : (
                  <div class="flex h-full w-full flex-col items-center justify-center gap-3 text-muted-foreground bg-[#C4A1FF]/20">
                    <Info className="h-10 w-10 opacity-70" />
                    <span class="text-sm font-bold font-head uppercase">Tidak ada preview</span>
                  </div>
                )}
              </div>

              {galleryImages.length > 0 && (
                <div
                  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4"
                  data-lightbox
                  aria-hidden="true"
                >
                  <button
                    type="button"
                    class="absolute inset-0 h-full w-full cursor-zoom-out"
                    data-lightbox-backdrop
                    aria-label="Close image preview"
                  />

                  <div class="relative z-10 flex max-h-[92vh] w-full max-w-6xl flex-col gap-4">
                    <div class="flex items-center justify-end gap-2 self-end rounded-sm border-2 border-black bg-white/95 p-2 shadow-brutal-sm">
                      <button type="button" class="rounded-sm border-2 border-black bg-white px-3 py-2 font-bold shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none" data-lightbox-zoom-out aria-label="Zoom out">
                        <ZoomOut className="h-4 w-4" />
                      </button>
                      <button type="button" class="rounded-sm border-2 border-black bg-white px-3 py-2 font-bold shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none" data-lightbox-zoom-in aria-label="Zoom in">
                        <ZoomIn className="h-4 w-4" />
                      </button>
                      <button type="button" class="rounded-sm border-2 border-black bg-white px-3 py-2 font-bold shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none" data-lightbox-close aria-label="Close image preview">
                        <X className="h-4 w-4" />
                      </button>
                    </div>

                    <div class="relative flex min-h-0 flex-1 items-center justify-center overflow-hidden rounded-lg border-[3px] border-black bg-black shadow-brutal">
                      {hasGallery && (
                        <>
                          <button
                            type="button"
                            class="absolute left-3 top-1/2 z-20 -translate-y-1/2 rounded-sm border-2 border-black bg-white/95 px-3 py-3 shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[-50%] hover:shadow-none"
                            data-lightbox-prev
                            aria-label="Previous image"
                          >
                            <ChevronLeft className="h-5 w-5" />
                          </button>
                          <button
                            type="button"
                            class="absolute right-3 top-1/2 z-20 -translate-y-1/2 rounded-sm border-2 border-black bg-white/95 px-3 py-3 shadow-brutal-sm transition-all hover:translate-x-[2px] hover:translate-y-[-50%] hover:shadow-none"
                            data-lightbox-next
                            aria-label="Next image"
                          >
                            <ChevronRight className="h-5 w-5" />
                          </button>
                        </>
                      )}

                      <div class="flex h-full w-full items-center justify-center overflow-auto p-4 md:p-6">
                        <img
                          src={galleryImages[0]}
                          alt={`${entry.data.title} preview`}
                          class="max-h-full max-w-full origin-center object-contain transition-transform duration-200"
                          data-lightbox-image
                        />
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>

          <!-- MDX Content Area -->
          <section class="rounded-xl border-[3px] border-black bg-white p-6 md:p-8 shadow-brutal prose lg:prose-lg max-w-none prose-headings:font-head prose-headings:font-black prose-headings:uppercase prose-a:text-primary prose-a:font-bold prose-img:border-2 prose-img:border-black prose-img:rounded-md">
            <Content />
          </section>
        </section>

        <!-- Sticky Sidebar -->
        <aside class="space-y-6 lg:sticky lg:top-24 h-fit">
          <div class="rounded-xl border-[3px] border-black bg-white p-6 shadow-brutal">
            <div class="mb-5 flex items-center gap-2 text-sm font-black font-head uppercase tracking-wider">
              <Globe className="h-4 w-4" />
              Project Links
            </div>

            <div class="grid gap-3">
              {!entry.data.link && !entry.data.github && <p class="text-sm font-medium text-muted-foreground">Belum ada tautan yang dibagikan.</p>}

              {entry.data.link && (
                <a href={entry.data.link} target="_blank" rel="noreferrer" class="w-full inline-flex items-center justify-between gap-2 px-4 py-3 bg-[#C4A1FF] border-2 border-black rounded-sm font-bold text-base shadow-[4px_4px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
                  <span class="flex items-center gap-2">
                    <Globe className="h-5 w-5" /> Visit Live Site
                  </span>
                  <ExternalLink className="h-4 w-4 opacity-70" />
                </a>
              )}

              {entry.data.github && (
                <a href={entry.data.github} target="_blank" rel="noreferrer" class="w-full inline-flex items-center justify-between gap-2 px-4 py-3 bg-white border-2 border-black rounded-sm font-bold text-base shadow-[4px_4px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
                  <span class="flex items-center gap-2">
                    <GitBranch className="h-5 w-5" /> Source Code
                  </span>
                  <ExternalLink className="h-4 w-4 opacity-70" />
                </a>
              )}
            </div>
          </div>

          <div class="rounded-xl border-[3px] border-black bg-white p-6 shadow-brutal">
            <div class="space-y-6">
              <div class="space-y-3">
                <div class="flex items-center gap-2 text-xs font-black font-head uppercase tracking-wider">
                  <Calendar className="h-4 w-4" />
                  Release Date
                </div>
                <p class="text-lg font-bold">{formattedDate}</p>
                <ViewCounter pageKey={`project:${slug}`} client:visible />
              </div>

              <div class="border-t-2 border-black/10 pt-4 space-y-3">
                <div class="flex items-center gap-2 text-xs font-black font-head uppercase tracking-wider">
                  <Layers className="h-4 w-4" />
                  Tech Stack
                </div>
                <div class="flex flex-wrap gap-2">
                  {entry.data.tags.map((tag) => (
                    <span class="text-xs font-bold font-head px-2.5 py-1 border-2 border-black bg-[#F4F4F5] rounded shadow-brutal-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <ReactionBar pageKey={`project:${slug}`} client:visible />
        </aside>
      </div>
    </div>
  </article>

  <Footer />
</Layout>

<script>
  const gallery = document.querySelector("[data-gallery]")
  const prevButton = document.querySelector("[data-gallery-prev]")
  const nextButton = document.querySelector("[data-gallery-next]")
  const dots = Array.from(document.querySelectorAll("[data-gallery-dot]"))
  const galleryOpenButtons = Array.from(document.querySelectorAll("[data-gallery-open]"))
  const lightbox = document.querySelector("[data-lightbox]")
  const lightboxBackdrop = document.querySelector("[data-lightbox-backdrop]")
  const lightboxClose = document.querySelector("[data-lightbox-close]")
  const lightboxImage = document.querySelector("[data-lightbox-image]")
  const lightboxPrev = document.querySelector("[data-lightbox-prev]")
  const lightboxNext = document.querySelector("[data-lightbox-next]")
  const lightboxZoomIn = document.querySelector("[data-lightbox-zoom-in]")
  const lightboxZoomOut = document.querySelector("[data-lightbox-zoom-out]")

  if (gallery && prevButton && nextButton && dots.length > 1) {
    const updateDots = () => {
      const slideWidth = gallery.clientWidth
      const activeIndex = Math.round(gallery.scrollLeft / Math.max(slideWidth, 1))

      dots.forEach((dot, index) => {
        dot.classList.toggle("bg-black", index === activeIndex)
        dot.classList.toggle("bg-white", index !== activeIndex)
      })
    }

    const scrollByPage = (direction) => {
      gallery.scrollBy({ left: gallery.clientWidth * direction, behavior: "smooth" })
    }

    prevButton.addEventListener("click", () => scrollByPage(-1))
    nextButton.addEventListener("click", () => scrollByPage(1))
    gallery.addEventListener("scroll", updateDots, { passive: true })
    updateDots()
  }

  if (gallery && lightbox && lightboxImage && galleryOpenButtons.length > 0) {
    const imageSources = JSON.parse(gallery.getAttribute("data-gallery-images") || "[]")
    let activeIndex = 0
    let zoomLevel = 1

    const applyZoom = () => {
      lightboxImage.style.transform = `scale(${zoomLevel})`
    }

    const syncLightboxImage = () => {
      lightboxImage.setAttribute("src", imageSources[activeIndex] || "")
      lightboxImage.setAttribute("alt", `${document.title.replace(" | Drenzzz Projects", "")} preview ${activeIndex + 1}`)
      zoomLevel = 1
      applyZoom()
    }

    const openLightbox = (index) => {
      activeIndex = index
      syncLightboxImage()
      lightbox.classList.remove("hidden")
      lightbox.classList.add("flex")
      lightbox.setAttribute("aria-hidden", "false")
      document.body.style.overflow = "hidden"
    }

    const closeLightbox = () => {
      lightbox.classList.add("hidden")
      lightbox.classList.remove("flex")
      lightbox.setAttribute("aria-hidden", "true")
      document.body.style.overflow = ""
      zoomLevel = 1
      applyZoom()
    }

    const stepLightbox = (direction) => {
      if (imageSources.length <= 1) return
      activeIndex = (activeIndex + direction + imageSources.length) % imageSources.length
      syncLightboxImage()
    }

    galleryOpenButtons.forEach((button) => {
      button.addEventListener("click", () => openLightbox(Number(button.getAttribute("data-gallery-index") || "0")))
    })

    lightboxBackdrop?.addEventListener("click", closeLightbox)
    lightboxClose?.addEventListener("click", closeLightbox)
    lightboxPrev?.addEventListener("click", () => stepLightbox(-1))
    lightboxNext?.addEventListener("click", () => stepLightbox(1))
    lightboxZoomIn?.addEventListener("click", () => {
      zoomLevel = Math.min(zoomLevel + 0.25, 3)
      applyZoom()
    })
    lightboxZoomOut?.addEventListener("click", () => {
      zoomLevel = Math.max(zoomLevel - 0.25, 1)
      applyZoom()
    })

    document.addEventListener("keydown", (event) => {
      if (lightbox.getAttribute("aria-hidden") === "true") return
      if (event.key === "Escape") closeLightbox()
      if (event.key === "ArrowLeft") stepLightbox(-1)
      if (event.key === "ArrowRight") stepLightbox(1)
      if ((event.key === "+" || event.key === "=") && !event.ctrlKey) {
        zoomLevel = Math.min(zoomLevel + 0.25, 3)
        applyZoom()
      }
      if (event.key === "-") {
        zoomLevel = Math.max(zoomLevel - 0.25, 1)
        applyZoom()
      }
    })
  }
</script>
