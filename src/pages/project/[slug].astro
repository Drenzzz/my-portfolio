---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/main.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import { ArrowLeft, Calendar, Layers, Globe, Github, ExternalLink, Info } from "lucide-react";

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = new Date(entry.data.publishDate).toLocaleDateString("id-ID", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---
<Layout title={`${entry.data.title} | Drenzzz Projects`} description={entry.data.description}>
  <Navbar />
  
  <article class="flex-1 relative min-h-screen pb-20 pt-8">
    <div class="container mx-auto max-w-7xl px-4">
      <div class="mb-8 flex items-center gap-4 text-sm text-foreground">
        <a
          href="/project"
          class="group inline-flex items-center gap-2 rounded-sm border-2 border-black bg-white px-4 py-2 font-bold shadow-brutal-sm hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all"
        >
          <ArrowLeft className="h-4 w-4" />
          Kembali ke Portfolio
        </a>
      </div>

      <div class="grid gap-10 lg:grid-cols-[1.3fr_0.9fr]">
        <section class="space-y-8">
          <div class="rounded-xl border-[3px] border-black bg-white p-6 md:p-8 shadow-brutal">
            <div class="space-y-4">
              <h1 class="font-head text-4xl font-black leading-tight tracking-tight md:text-5xl lg:text-6xl uppercase">{entry.data.title}</h1>
              <p class="max-w-3xl text-lg text-muted-foreground md:text-xl font-medium">{entry.data.description}</p>
            </div>

            <div class="mt-8">
              <div class="relative overflow-hidden rounded-lg border-[3px] border-black bg-muted aspect-video shadow-brutal-sm">
                {entry.data.image ? (
                  <img src={entry.data.image} alt={entry.data.title} class="w-full h-full object-cover" />
                ) : (
                  <div class="flex h-full w-full flex-col items-center justify-center gap-3 text-muted-foreground bg-[#C4A1FF]/20">
                    <Info className="h-10 w-10 opacity-70" />
                    <span class="text-sm font-bold font-head uppercase">Tidak ada preview</span>
                  </div>
                )}
              </div>
            </div>
          </div>

          <!-- MDX Content Area -->
          <section class="rounded-xl border-[3px] border-black bg-white p-6 md:p-8 shadow-brutal prose lg:prose-lg max-w-none prose-headings:font-head prose-headings:font-black prose-headings:uppercase prose-a:text-primary prose-a:font-bold prose-img:border-2 prose-img:border-black prose-img:rounded-md">
            <Content />
          </section>
        </section>

        <!-- Sticky Sidebar -->
        <aside class="space-y-6 lg:sticky lg:top-24 h-fit">
          <div class="rounded-xl border-[3px] border-black bg-white p-6 shadow-brutal">
            <div class="mb-5 flex items-center gap-2 text-sm font-black font-head uppercase tracking-wider">
              <Globe className="h-4 w-4" />
              Project Links
            </div>

            <div class="grid gap-3">
              {!entry.data.link && !entry.data.github && <p class="text-sm font-medium text-muted-foreground">Belum ada tautan yang dibagikan.</p>}

              {entry.data.link && (
                <a href={entry.data.link} target="_blank" rel="noreferrer" class="w-full inline-flex items-center justify-between gap-2 px-4 py-3 bg-[#C4A1FF] border-2 border-black rounded-sm font-bold text-base shadow-[4px_4px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
                  <span class="flex items-center gap-2">
                    <Globe className="h-5 w-5" /> Visit Live Site
                  </span>
                  <ExternalLink className="h-4 w-4 opacity-70" />
                </a>
              )}

              {entry.data.github && (
                <a href={entry.data.github} target="_blank" rel="noreferrer" class="w-full inline-flex items-center justify-between gap-2 px-4 py-3 bg-white border-2 border-black rounded-sm font-bold text-base shadow-[4px_4px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
                  <span class="flex items-center gap-2">
                    <Github className="h-5 w-5" /> Source Code
                  </span>
                  <ExternalLink className="h-4 w-4 opacity-70" />
                </a>
              )}
            </div>
          </div>

          <div class="rounded-xl border-[3px] border-black bg-white p-6 shadow-brutal">
            <div class="space-y-6">
              <div class="space-y-3">
                <div class="flex items-center gap-2 text-xs font-black font-head uppercase tracking-wider">
                  <Calendar className="h-4 w-4" />
                  Release Date
                </div>
                <p class="text-lg font-bold">{formattedDate}</p>
              </div>

              <div class="border-t-2 border-black/10 pt-4 space-y-3">
                <div class="flex items-center gap-2 text-xs font-black font-head uppercase tracking-wider">
                  <Layers className="h-4 w-4" />
                  Tech Stack
                </div>
                <div class="flex flex-wrap gap-2">
                  {entry.data.tags.map((tag) => (
                    <span class="text-xs font-bold font-head px-2.5 py-1 border-2 border-black bg-[#F4F4F5] rounded shadow-brutal-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <Footer />
</Layout>
