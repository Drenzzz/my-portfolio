---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import AboutHeroSection from "@/components/about/AboutHeroSection.astro"
import ConnectNowSection from "@/components/about/ConnectNowSection.astro"
import JourneySection from "@/components/about/JourneySection.astro"
import SkillsArsenalSection from "@/components/about/SkillsArsenalSection.astro"
import CertificatesPreview from "@/components/about/CertificatesPreview.astro"
import ClosingCTASection from "@/components/about/ClosingCTASection.astro"
import { Guestbook } from "@/components/islands/Guestbook"
import { ViewCounter } from "@/components/islands/ViewCounter"

export const prerender = true

const title = "About | Drenzzz"
const description =
  "Get to know more about my background, education, and the tech stack I use to build robust applications."
---

<Layout title={title} description={description}>
  <Navbar />

  <main class="relative w-full flex-1 bg-[#f8f9fa]">
    <div
      class="absolute inset-0 z-0 opacity-[0.15]"
      style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 24px 24px;"
    >
    </div>
    <div
      class="floating-circle absolute bottom-24 right-12 z-0 h-36 w-36 rounded-full border-[3px] border-black bg-[#C4A1FF] opacity-70"
    >
    </div>
    <div
      class="floating-circle absolute top-32 left-8 z-0 h-28 w-28 rounded-full border-[3px] border-black bg-[#E7F193] opacity-70"
    >
    </div>

    <div class="relative z-10">
      <section class="container mx-auto px-4 pt-12 md:pt-20">
        <div
          id="about-page-hero-motion-root"
          class="mb-10 flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
        >
          <div data-motion-group="about-page-hero-copy">
            <div
              class="inline-block -rotate-2 border-4 border-black bg-white px-6 py-2 shadow-brutal transition-transform hover:rotate-0"
              data-motion
            >
              <h1
                class="font-head text-4xl font-black tracking-tight text-black uppercase md:text-6xl"
              >
                About
              </h1>
            </div>
            <p
              class="mt-5 max-w-2xl rounded-sm p-2 text-lg font-semibold text-muted-foreground"
              data-motion
              style="--motion-offset-y: 18px;"
            >
              Get to know more about my background, education, and the tech stack
              I use to build robust applications.
            </p>
          </div>

          <div
            class="font-head w-fit rounded-sm border-2 border-black bg-[#C4A1FF] px-3 py-2 text-sm font-black shadow-brutal-sm"
            data-motion
            style="--motion-offset-y: 18px;"
          >
            <ViewCounter pageKey="page:/about" client:visible />
          </div>
        </div>

        <AboutHeroSection />
      </section>

      <section class="container mx-auto px-4 py-8 md:py-12">
        <ConnectNowSection />
      </section>

      <section class="container mx-auto px-4 py-16 md:py-24">
        <JourneySection />
      </section>

      <SkillsArsenalSection />

      <CertificatesPreview />

      <Guestbook pageKey="page:/about" client:visible />

      <ClosingCTASection />
    </div>

    <Footer />
  </main>

  <style>
    .floating-circle {
      animation: float-circle 8s ease-in-out infinite;
    }

    .floating-circle:nth-child(2) {
      animation-delay: -2s;
      animation-duration: 10s;
    }

    @keyframes float-circle {
      0%, 100% {
        transform: translateY(0) translateX(0);
      }
      25% {
        transform: translateY(-12px) translateX(4px);
      }
      50% {
        transform: translateY(-6px) translateX(-6px);
      }
      75% {
        transform: translateY(-16px) translateX(2px);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .floating-circle {
        animation: none;
      }
    }
  </style>

  <script>
    import { bindInViewReveal } from "@/lib/animation/motion"

    const pageHeroRoot = document.getElementById("about-page-hero-motion-root")
    if (pageHeroRoot && pageHeroRoot.dataset.motionBound !== "true") {
      pageHeroRoot.dataset.motionBound = "true"

      bindInViewReveal(pageHeroRoot, "[data-motion-group='about-page-hero-copy'] [data-motion]", {
        amount: 0.2,
        delay: 0.04,
        duration: 0.4,
        staggerDelay: 0.12,
        offsetY: 16,
      })

      bindInViewReveal(pageHeroRoot, "[data-motion]:last-of-type", {
        amount: 0.2,
        delay: 0.08,
        duration: 0.4,
        offsetY: 18,
        scale: 0.98,
      })
    }
  </script>
</Layout>
