---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import AboutHeroSection from "@/components/about/AboutHeroSection.astro"
import ConnectNowSection from "@/components/about/ConnectNowSection.astro"
import JourneySection from "@/components/about/JourneySection.astro"
import SkillsArsenalSection from "@/components/about/SkillsArsenalSection.astro"
import CertificatesPreview from "@/components/about/CertificatesPreview.astro"
import ClosingCTASection from "@/components/about/ClosingCTASection.astro"
import { Guestbook } from "@/components/islands/Guestbook"
import { ViewCounter } from "@/components/islands/ViewCounter"

export const prerender = true

const title = "About | Drenzzz"
const description =
  "Get to know more about my background, education, and the tech stack I use to build robust applications."
---

<Layout title={title} description={description}>
  <Navbar />

  <main class="relative w-full flex-1 bg-[#f8f9fa]">
    <div
      class="absolute inset-0 z-0 opacity-[0.15]"
      style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 24px 24px;"
    >
    </div>

    <div class="relative z-10">
      <section class="container mx-auto px-4 pt-12 md:pt-20">
        <div class="mb-4 flex justify-end">
          <ViewCounter pageKey="page:/about" client:visible />
        </div>
        <AboutHeroSection />
      </section>

      <section class="container mx-auto px-4 py-8 md:py-12">
        <ConnectNowSection />
      </section>

      <section class="container mx-auto px-4 py-16 md:py-24">
        <JourneySection />
      </section>

      <SkillsArsenalSection />

      <CertificatesPreview />

      <Guestbook pageKey="page:/about" client:visible />

      <ClosingCTASection />
    </div>

    <Footer />
  </main>
</Layout>
