---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/layout/Navbar.astro"
import Footer from "@/components/layout/Footer.astro"
import { Guestbook } from "@/components/islands/Guestbook"
import { ViewCounter } from "@/components/islands/ViewCounter"

export const prerender = true

const title = "Guestbook | Drenzzz"
const description = "Read and leave a message on Drenzzz's portfolio guestbook."
---

<Layout title={title} description={description}>
  <Navbar />

  <main class="relative flex-1 overflow-hidden bg-[#f8f9fa]">
    <div
      class="absolute inset-0 z-0 opacity-[0.15]"
      style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 24px 24px;"
    >
    </div>
    <div
      class="absolute top-20 right-8 z-0 h-36 w-36 rounded-full border-[3px] border-black bg-[#C4A1FF] opacity-80"
    >
    </div>
    <div
      class="absolute bottom-16 left-8 z-0 h-24 w-24 rounded-full border-[3px] border-black bg-[#E7F193] opacity-80"
    >
    </div>

    <section class="relative z-10 container mx-auto px-4 py-12 md:py-20">
      <div
        class="mb-10 flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <div
            class="inline-block -rotate-2 border-4 border-black bg-white px-6 py-2 shadow-brutal transition-transform hover:rotate-0"
          >
            <h1
              class="font-head text-4xl font-black tracking-tight text-black uppercase md:text-6xl"
            >
              Guestbook
            </h1>
          </div>
          <p
            class="mt-5 max-w-2xl rounded-sm bg-white/85 p-2 text-lg font-semibold text-muted-foreground"
          >
            Leave a note, feedback, collaboration idea, or just say hello.
          </p>
        </div>

        <div
          class="font-head w-fit rounded-sm border-2 border-black bg-[#C4A1FF] px-3 py-2 text-sm font-black shadow-brutal-sm"
        >
          <ViewCounter pageKey="page:/guestbook" client:visible />
        </div>
      </div>

      <div class="mx-auto max-w-4xl">
        <Guestbook pageKey="page:/about" client:visible />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
