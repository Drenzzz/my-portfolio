# GitHub GraphQL API Token (Requires repo & user scopes)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=drenzzz
GITHUB_STATS_CACHE_TTL_MS=600000
GITHUB_REQUEST_TIMEOUT_MS=8000

# Lanyard Discord User ID (PUBLIC_ prefix exposes to client)
PUBLIC_DISCORD_ID=your_discord_id_here
PUBLIC_LANYARD_MAX_ATTEMPTS=6
PUBLIC_LANYARD_ENABLE_SNAPSHOT=true
PUBLIC_LANYARD_RETRY_BASE_DELAY_MS=3000
PUBLIC_LANYARD_RETRY_JITTER_MS=250

# Vercel KV (Upstash) credentials
KV_URL=redis://your_kv_url_here:port
KV_REST_API_URL=https://your_kv_rest_url_here
KV_REST_API_TOKEN=your_kv_rest_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token_here

# Server feature tuning
VIEW_COUNT_THROTTLE_SECONDS=3600
GUESTBOOK_MAX_MESSAGE_LENGTH=280
GUESTBOOK_RATE_LIMIT_WINDOW_SECONDS=300
GUESTBOOK_RATE_LIMIT_MAX_REQUESTS=5
REACTION_RATE_LIMIT_WINDOW_SECONDS=60
REACTION_RATE_LIMIT_MAX_REQUESTS=12
